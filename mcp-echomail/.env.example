# MCP server port
MCP_PORT=3740

# Comma-separated list of allowed API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEYS=your-secret-key-here,optional-second-key

# PostgreSQL — same values as your BinktermPHP .env
DB_HOST=localhost
DB_PORT=5432
DB_NAME=binktest
DB_USER=binkterm
DB_PASSWORD=yourpassword

# Optional: set to any value to enable SSL (self-signed certs accepted)
# DB_SSLMODE=require
