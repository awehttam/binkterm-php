            if (xhr && xhr.responseJSON) {
                errorMsg += ': ' + apiError(xhr.responseJSON, xhr.status + ' ' + xhr.statusText);
            } else {
                errorMsg += ': ' + xhr.status + ' ' + xhr.statusText;
            }
            showError(errorMsg);
        }
    });
