                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 position-relative" style="background:#000; min-height:280px;">
                <video id="meshcoreQrVideo" autoplay playsinline muted
                       style="width:100%; display:block; max-height:350px; object-fit:cover;"></video>
                <canvas id="meshcoreQrCanvas" style="display:none;"></canvas>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
                    <div style="width:190px;height:190px;border:2px solid rgba(255,255,255,0.7);border-radius:6px;box-shadow:0 0 0 9999px rgba(0,0,0,0.45);"></div>
                </div>
            </div>
            <div class="modal-footer d-block text-center py-2">
                <p class="mb-2 text-muted small" id="meshcoreQrStatus">
                    {{ t('ui.settings.meshcore.scan_qr_prompt', {}, locale, ['common']) }}
                </p>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    {{ t('ui.common.cancel', {}, locale, ['common']) }}
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/jsqr.js"></script>
<script src="/vendor/openpgp-6.2.2/openpgp.min.js"></script>
<script>
function uiT(key, fallback, params = {}) {
    if (window.t) {
        return window.t(key, params, fallback);
    }
    return fallback;
}

const currentPgpAccount = {
    username: {{ current_user.username|json_encode|raw }},
    real_name: {{ (current_user.real_name ?: current_user.username)|json_encode|raw }}
};
const siteHostname = (() => {
    try {
        return new URL({{ site_url|json_encode|raw }}).hostname;
    } catch (error) {
        return window.location.hostname || '';
    }
})();

let settingsLoaded = false;
let initialSettingsSnapshot = {};

$(document).ready(function() {
    setSettingsLoading('#settingsForm', true);
    loadSettings();
    loadEchomailIgnoreRules();

    // Restore last active tab
    const savedTab = UserStorage.getItem('settingsActiveTab');
    if (savedTab) {
        const btn = document.querySelector(`[data-bs-target="${savedTab}"]`);
        if (btn) bootstrap.Tab.getOrCreateInstance(btn).show();
    }

    // Save active tab on change; toggle Save button visibility
    document.querySelectorAll('#settingsTabs [data-bs-toggle="pill"]').forEach(function(btn) {
        btn.addEventListener('shown.bs.tab', function(e) {
            const target = e.target.getAttribute('data-bs-target');
            UserStorage.setItem('settingsActiveTab', target);
            $('#saveButtonRow').toggle(
                target !== '#tab-account' && target !== '#tab-ai' && target !== '#tab-pgp' && target !== '#tab-meshcore'
            );
        });
    });

    const pgpTabAvailable = document.getElementById('tab-pgp-btn') !== null;

    // Hide Save button if Account, AI, PGP, or MeshCore tab was restored
    if (savedTab === '#tab-account' || savedTab === '#tab-ai' || (pgpTabAvailable && savedTab === '#tab-pgp') || savedTab === '#tab-meshcore') {
        $('#saveButtonRow').hide();
    }

    // Load TOTP status when the Account tab is shown.
    document.getElementById('tab-account-btn')?.addEventListener('shown.bs.tab', function() {
        loadPacketBbsTotpStatus();
    });
    if (savedTab === '#tab-account') {
        loadPacketBbsTotpStatus();
    }

    // Load MCP key status when the AI tab is shown
    document.getElementById('tab-ai-btn')?.addEventListener('shown.bs.tab', function() {
        loadMcpKeyStatus();
    });
    if (savedTab === '#tab-ai') {
        loadMcpKeyStatus();
    }

    document.getElementById('tab-pgp-btn')?.addEventListener('shown.bs.tab', function() {
        loadPgpKeys();
    });
    if (savedTab === '#tab-pgp') {
        loadPgpKeys();
    }

    // Load MeshCore contacts when the MeshCore tab is shown
    document.getElementById('tab-meshcore-btn')?.addEventListener('shown.bs.tab', function() {
        loadMeshcoreContacts();
    });
    if (savedTab === '#tab-meshcore') {
        loadMeshcoreContacts();
    }

    // Apply theme immediately when changed
    $('#theme').on('change', function() {
        const newTheme = $(this).val();
        $('#theme-stylesheet').attr('href', newTheme + '?v=' + Date.now());
    });

    $('#signatureText').on('input', function() {
        enforceSignatureLineLimit(this);
    });

    $('#chatNotificationSound, #echomailNotificationSound, #netmailNotificationSound, #fileNotificationSound').on('change', function() {
        previewNotificationSound($(this).val());
    });
});

function enforceSignatureLineLimit(textarea) {
    const value = textarea.value || '';
    const lines = value.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
    if (lines.length > 4) {
        textarea.value = lines.slice(0, 4).join('\n');
    }
}

function previewNotificationSound(soundName) {
    if (soundName === 'disabled') {
        return;
    }
    const selectedSound = typeof soundName === 'string' && /^notify\d+$/.test(soundName)
        ? soundName
        : 'notify1';
    const audio = new Audio(`/sounds/${selectedSound}.mp3`);
    audio.play().catch(function() {
        // Ignore autoplay/playback failures during preview.
    });
}

function loadSettings() {
    return $.get('/api/user/settings')
        .done(function(response) {
            const data = response.success ? response.settings : response;

            if (data.messages_per_page) $('#messagesPerPage').val(data.messages_per_page);
            if (data.timezone) $('#timezone').val(data.timezone);
            if (data.locale) $('#locale').val(data.locale);
            if (data.date_format) $('#dateFormat').val(data.date_format);
            if (data.theme) $('#theme').val(data.theme);
            if (data.shell) $('#shellPreference').val(data.shell);
            if (data.default_echo_list) $('#defaultEchoList').val(data.default_echo_list);
            if (data.font_family) $('#fontFamily').val(data.font_family);
            if (data.font_size) $('#fontSize').val(data.font_size);
            if (data.signature_text !== undefined) $('#signatureText').val(data.signature_text);
            if (data.default_tagline !== undefined) $('#defaultTagline').val(data.default_tagline || '');
            if (typeof window.userSettings !== 'undefined') {
                Object.assign(window.userSettings, data);
            }

            // Threading preferences
            $('#threadedView').prop('checked', data.threaded_view === true);
            $('#netmailThreadedView').prop('checked', data.netmail_threaded_view === true);
            $('#rememberPagePosition').prop('checked', data.remember_page_position === true);

            // Quote coloring (defaults to true if not set)
            $('#quoteColoring').prop('checked', data.quote_coloring !== false);

            // Media render mode (defaults to 'click')
            $('input[name="media_render_mode"][value="' + (data.media_render_mode || 'click') + '"]').prop('checked', true);

            // Notifications
            $('#chatNotificationSound').val(data.chat_notification_sound || 'notify3');
            $('#echomailNotificationSound').val(data.echomail_notification_sound || 'disabled');
            $('#netmailNotificationSound').val(data.netmail_notification_sound || 'notify1');
            $('#fileNotificationSound').val(data.file_notification_sound || 'disabled');
            $('#forwardNetmailEmail').prop('checked', data.forward_netmail_email === true);
            $('#echomailDigest').val(data.echomail_digest || 'none');
            $('#echomailBadgeMode').val(data.echomail_badge_mode || 'new');

            // Commented out settings (not yet implemented)
            $('#showOrigin').prop('checked', data.show_origin !== false);
            $('#showTearline').prop('checked', data.show_tearline !== false);
            $('#autoRefresh').prop('checked', data.auto_refresh === true);

            initialSettingsSnapshot = collectCurrentSettings();
            settingsLoaded = true;
            $('#settingsSaveButton').prop('disabled', false);
            $('#settingsForm').attr('aria-busy', 'false');
            setSettingsLoading('#settingsForm', false);
        })
        .fail(function() {
            console.log(uiT('ui.settings.load_failed_console', 'Failed to load settings'));
            $('#settingsForm').attr('aria-busy', 'false');
            setSettingsLoading('#settingsForm', false);
        });
}

function loadEchomailIgnoreRules() {
    const container = $('#echomailIgnoreRulesList');
    container.html(`<div class="text-muted"><i class="fas fa-spinner fa-spin me-2"></i>${uiT('ui.settings.echomail_ignore_rules.loading', 'Loading ignore rules...')}</div>`);

    $.get('/api/user/echomail-ignore-rules')
        .done(function(response) {
            const rules = Array.isArray(response.rules) ? response.rules : [];

            if (rules.length === 0) {
                container.html(`<div class="text-muted">${uiT('ui.settings.echomail_ignore_rules.empty', 'No echomail ignore rules saved.')}</div>`);
                return;
            }

            let html = '<div class="list-group">';
            rules.forEach(function(rule) {
                const senderDisplay = rule.sender_address
                    ? `${escapeHtml(rule.sender_name)} &lt;${escapeHtml(rule.sender_address)}&gt;`
                    : escapeHtml(rule.sender_name);
                html += `
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div><strong>${senderDisplay}</strong></div>
                                <div class="text-muted small">${uiT('ui.settings.echomail_ignore_rules.subject_contains_prefix', 'Subject contains:')} ${escapeHtml(rule.subject_contains || '')}</div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteEchomailIgnoreRule(${Number(rule.id)})">
                                <i class="fas fa-trash me-1"></i>${uiT('ui.settings.echomail_ignore_rules.remove', 'Remove')}
                            </button>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            container.html(html);
        })
        .fail(function(xhr) {
            const error = window.getApiErrorMessage
                ? window.getApiErrorMessage(xhr.responseJSON, uiT('ui.settings.echomail_ignore_rules.load_failed', 'Failed to load ignore rules'))
                : uiT('ui.settings.echomail_ignore_rules.load_failed', 'Failed to load ignore rules');
            container.html(`<div class="text-danger">${escapeHtml(error)}</div>`);
        });
}

function loadPgpKeys() {
    const container = document.getElementById('pgpKeysContainer');
    if (!container) {
        return;
    }

    container.innerHTML = `<div class="text-center py-3 text-muted"><i class="fas fa-spinner fa-spin me-2"></i>${uiT('ui.common.loading', 'Loading…')}</div>`;

    $.get('/api/user/pgp/keys')
        .done(function(response) {
            renderPgpKeys(Array.isArray(response.keys) ? response.keys : []);
        })
        .fail(function(xhr) {
            const error = window.getApiErrorMessage
                ? window.getApiErrorMessage(xhr.responseJSON, uiT('errors.pgp.load_failed', 'Failed to load PGP keys'))
                : uiT('errors.pgp.load_failed', 'Failed to load PGP keys');
            container.innerHTML = `<div class="p-3 text-danger">${escapeHtml(error)}</div>`;
        });
}

function renderPgpKeys(keys) {
    const container = document.getElementById('pgpKeysContainer');
    if (!container) {
        return;
    }

    window.currentPgpKeys = Array.isArray(keys) ? keys : [];

    if (!keys.length) {
        container.innerHTML = `<div class="p-4 text-center text-muted">${uiT('ui.settings.pgp.no_keys', 'No PGP keys saved yet.')}</div>`;
        return;
    }

    let html = `<div class="p-3 border-bottom">
        <label for="pgpPrimarySelector" class="form-label mb-1">${uiT('ui.settings.pgp.primary_selector', 'Preferred public key')}</label>
        <select id="pgpPrimarySelector" class="form-select" onchange="setPrimaryPgpKey(this.value)">
            ${keys.map(function(key) {
                const label = key.label ? `${key.label} ` : '';
                const suffix = key.fingerprint.slice(-8);
                const selected = key.is_primary ? ' selected' : '';
                return `<option value="${escapeHtml(key.fingerprint)}"${selected}>${escapeHtml(label)}${escapeHtml(suffix)}</option>`;
            }).join('')}
        </select>
        <div class="form-text mt-2">${uiT('ui.settings.pgp.primary_help', 'Pick a key here, or use the Make Primary button in the table below, to change which public key is listed as your preferred key on the keyserver.')}</div>
    </div>
    <div class="table-responsive"><table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>${uiT('ui.settings.pgp.col_primary', 'Primary')}</th>
                <th>${uiT('ui.settings.pgp.col_label', 'Label')}</th>
                <th>${uiT('ui.settings.pgp.col_fingerprint', 'Fingerprint')}</th>
                <th>${uiT('ui.settings.pgp.col_source', 'Source')}</th>
                <th>${uiT('ui.settings.pgp.col_created', 'Created')}</th>
                <th>${uiT('ui.settings.pgp.col_actions', 'Actions')}</th>
            </tr>
        </thead><tbody>`;

    keys.forEach(function(key) {
        const created = formatPgpDate(key.key_created_at || key.created_at);
        const label = key.label
            ? escapeHtml(key.label)
            : '<span class="text-muted">—</span>';
        const source = key.source === 'managed'
            ? uiT('ui.settings.pgp.source_managed', 'BBS managed')
            : uiT('ui.settings.pgp.source_uploaded', 'Uploaded');
        const hasPrivate = key.has_private_key
            ? `<div class="text-muted small">${uiT('ui.settings.pgp.private_key_available', 'Encrypted private key stored')}</div>`
            : '';
        const userIdLine = key.user_id_string
            ? `<div class="text-muted small">${escapeHtml(key.user_id_string)}</div>`
            : '';

        html += `<tr>
            <td>
                ${key.is_primary
                    ? `<span class="badge bg-success">${uiT('ui.settings.pgp.primary_selected', 'Primary')}</span>`
                    : `<span class="text-muted">${uiT('ui.settings.pgp.secondary_key', 'Secondary')}</span>`}
            </td>
            <td>
                <button type="button" class="btn btn-link p-0 text-start text-decoration-underline fw-semibold"
                        style="color: inherit;"
                        onclick="openPgpKeyDetails('${escapeJs(key.fingerprint)}')">${label}</button>
                ${userIdLine}
            </td>
            <td>
                <button type="button" class="btn btn-link p-0 text-start text-decoration-underline"
                        style="color: inherit;"
                        onclick="openPgpKeyDetails('${escapeJs(key.fingerprint)}')">
                    <span class="font-monospace">${escapeHtml(key.fingerprint)}</span>
                </button>
                ${hasPrivate}
            </td>
            <td>${escapeHtml(source)}</td>
            <td>${escapeHtml(created)}</td>
            <td>
                <div class="d-flex gap-2">
                    ${key.is_primary
                        ? `<button type="button" class="btn btn-sm btn-success" disabled>${uiT('ui.settings.pgp.current_primary_button', 'Current Primary')}</button>`
                        : `<button type="button" class="btn btn-sm btn-outline-success" onclick="setPrimaryPgpKey('${escapeJs(key.fingerprint)}')">${uiT('ui.settings.pgp.make_primary_button', 'Make Primary')}</button>`}
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyPgpFingerprint('${escapeJs(key.fingerprint)}')">
                        <i class="fas fa-copy"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deletePgpKey('${escapeJs(key.fingerprint)}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </td>
        </tr>`;
    });

    html += '</tbody></table></div>';
    container.innerHTML = html;
}

function uploadPgpPublicKey() {
    const armoredPublicKey = ($('#pgpPublicKey').val() || '').trim();
    const label = ($('#pgpUploadLabel').val() || '').trim();

    if (!armoredPublicKey) {
        setPgpStatus('danger', uiT('errors.pgp.public_key_required', 'A public key is required'));
        return;
    }

    setPgpStatus('info', uiT('ui.settings.pgp.uploading', 'Uploading public key...'));

    $.ajax({
        url: '/api/user/pgp/keys',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({
            armored_public_key: armoredPublicKey,
            label: label
        }),
        success: function(response) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, uiT('ui.settings.pgp.upload_success', 'PGP public key saved.'))
                : uiT('ui.settings.pgp.upload_success', 'PGP public key saved.');
            $('#pgpPublicKey').val('');
            $('#pgpUploadLabel').val('');
            setPgpStatus('success', successMessage);
            loadPgpKeys();
        },
        error: function(xhr) {
            const error = window.getApiErrorMessage
                ? window.getApiErrorMessage(xhr.responseJSON, uiT('errors.pgp.invalid_key', 'Invalid PGP public key'))
                : uiT('errors.pgp.invalid_key', 'Invalid PGP public key');
            setPgpStatus('danger', error);
        }
    });
}

async function generateManagedPgpKey() {
    if (!window.openpgp || typeof window.openpgp.generateKey !== 'function') {
        setPgpStatus('warning', uiT('ui.settings.pgp.openpgp_missing', 'OpenPGP.js is not installed on this BBS yet, so browser key generation is not available.'));
        return;
    }

    const passphrase = ($('#pgpPassphrase').val() || '').trim();
    const confirmPassphrase = ($('#pgpPassphraseConfirm').val() || '').trim();
    const label = ($('#pgpManagedLabel').val() || '').trim();
    const effectiveLabel = label || uiT('ui.settings.pgp.managed_label_placeholder', 'BinktermPHP managed key');

    if (passphrase.length < 8) {
        setPgpStatus('danger', uiT('errors.pgp.passphrase_too_short', 'Use a longer PGP passphrase.'));
        return;
    }
    if (passphrase !== confirmPassphrase) {
        setPgpStatus('danger', uiT('errors.pgp.passphrase_mismatch', 'Passphrase confirmation does not match.'));
        return;
    }

    setPgpStatus('info', uiT('ui.settings.pgp.generating', 'Generating PGP keypair...'));

    try {
        const email = currentPgpAccount.username && siteHostname
            ? `${currentPgpAccount.username}@${siteHostname}`
            : null;
        const userId = {
            name: currentPgpAccount.real_name
        };
        if (email) {
            userId.email = email;
        }
        const keyOptions = {
            type: 'ecc',
            curve: 'curve25519',
            userIDs: [userId],
            passphrase: passphrase,
            format: 'armored'
        };
        const generated = await window.openpgp.generateKey(keyOptions);

        await $.ajax({
            url: '/api/user/pgp/keys/managed',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                armored_public_key: generated.publicKey,
                encrypted_private_key: generated.privateKey,
                label: effectiveLabel
            })
        });

        $('#pgpManagedLabel').val('');
        $('#pgpPassphrase').val('');
        $('#pgpPassphraseConfirm').val('');
        setPgpStatus('success', uiT('ui.settings.pgp.generate_success', 'Managed PGP key generated and saved.'));
        loadPgpKeys();
    } catch (error) {
        setPgpStatus('danger', uiT('errors.pgp.generation_failed', 'Failed to generate managed PGP key.'));
    }
}

function setPrimaryPgpKey(fingerprint) {
    if (!fingerprint) {
        return;
    }

    $.post(`/api/user/pgp/keys/${encodeURIComponent(fingerprint)}/primary`)
        .done(function(response) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, uiT('ui.settings.pgp.primary_updated', 'Primary PGP key updated.'))
                : uiT('ui.settings.pgp.primary_updated', 'Primary PGP key updated.');
            setPgpStatus('success', successMessage);
            loadPgpKeys();
        })
        .fail(function(xhr) {
            const error = window.getApiErrorMessage
                ? window.getApiErrorMessage(xhr.responseJSON, uiT('errors.pgp.save_failed', 'Failed to save PGP key'))
                : uiT('errors.pgp.save_failed', 'Failed to save PGP key');
            setPgpStatus('danger', error);
        });
}

function deletePgpKey(fingerprint) {
    if (!confirm(uiT('ui.settings.pgp.delete_confirm', 'Delete this PGP key?'))) {
        return;
    }

    $.ajax({
        url: `/api/user/pgp/keys/${encodeURIComponent(fingerprint)}`,
        method: 'DELETE',
        success: function(response) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, uiT('ui.settings.pgp.delete_success', 'PGP key deleted.'))
                : uiT('ui.settings.pgp.delete_success', 'PGP key deleted.');
            setPgpStatus('success', successMessage);
            loadPgpKeys();
        },
        error: function(xhr) {
            const error = window.getApiErrorMessage
                ? window.getApiErrorMessage(xhr.responseJSON, uiT('errors.pgp.delete_failed', 'Failed to delete PGP key'))
                : uiT('errors.pgp.delete_failed', 'Failed to delete PGP key');
            setPgpStatus('danger', error);
        }
    });
}

function copyPgpFingerprint(fingerprint) {
    if (!navigator.clipboard || typeof navigator.clipboard.writeText !== 'function') {
        setPgpStatus('danger', uiT('errors.generic.copy_failed', 'Copy failed.'));
        return;
    }

    navigator.clipboard.writeText(fingerprint)
        .then(function() {
            setPgpStatus('success', uiT('ui.settings.pgp.copy_success', 'Fingerprint copied.'));
        })
        .catch(function() {
            setPgpStatus('danger', uiT('errors.generic.copy_failed', 'Copy failed.'));
        });
}

function setPgpStatus(level, message) {
    $('#pgpStatus').show().html(`
        <div class="alert alert-${level}">
            ${escapeHtml(message)}
        </div>
    `);
}

function formatPgpDate(value) {
    if (!value) {
        return '—';
    }
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
        return value;
    }
    return date.toLocaleString();
}

function openPgpKeyDetails(fingerprint) {
    const keys = Array.isArray(window.currentPgpKeys) ? window.currentPgpKeys : [];
    const key = keys.find(function(entry) {
        return String(entry.fingerprint || '').toUpperCase() === String(fingerprint || '').toUpperCase();
    });
    if (!key) {
        return;
    }

    const setText = function(id, value, fallback) {
        const el = document.getElementById(id);
        if (!el) return;
        const text = value !== undefined && value !== null && String(value).trim() !== '' ? String(value) : (fallback || '—');
        el.textContent = text;
    };

    const modal = document.getElementById('pgpKeyDetailsModal');
    if (!modal) {
        return;
    }

    const source = key.source === 'managed'
        ? uiT('ui.settings.pgp.source_managed', 'BBS managed')
        : uiT('ui.settings.pgp.source_uploaded', 'Uploaded');
    const primary = key.is_primary
        ? uiT('ui.settings.pgp.primary_selected', 'Primary')
        : uiT('ui.settings.pgp.secondary_key', 'Secondary');
    const privateKey = key.has_private_key
        ? uiT('ui.settings.pgp.private_key_available', 'Encrypted private key stored')
        : uiT('ui.common.no', 'No');
    const username = currentPgpAccount.username || '—';
    const realName = currentPgpAccount.real_name || username;
    const subtitle = `${realName} @ ${username}`;

    setText('pgpKeyDetailsSubtitle', subtitle, '');
    setText('pgpKeyDetailsLabel', key.label, '—');
    setText('pgpKeyDetailsUsername', username, '—');
    setText('pgpKeyDetailsRealName', realName, '—');
    setText('pgpKeyDetailsEmail', key.email, '—');
    setText('pgpKeyDetailsFingerprint', String(key.fingerprint || '').toUpperCase(), '—');
    setText('pgpKeyDetailsSource', source, '—');
    setText('pgpKeyDetailsCreated', formatPgpDate(key.key_created_at || key.created_at), '—');
    setText('pgpKeyDetailsPrimary', primary, '—');
    setText('pgpKeyDetailsPrivate', privateKey, '—');
    setText('pgpKeyDetailsAlgorithm', key.key_algorithm || '—', '—');
    setText('pgpKeyDetailsUserId', key.user_id_string, '—');

    bootstrap.Modal.getOrCreateInstance(modal).show();
}

function deleteEchomailIgnoreRule(ruleId) {
    if (!confirm(uiT('ui.settings.echomail_ignore_rules.remove_confirm', 'Remove this echomail ignore rule?'))) {
        return;
    }

    $.ajax({
        url: `/api/user/echomail-ignore-rules/${encodeURIComponent(ruleId)}`,
        method: 'DELETE',
        success: function(response) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, uiT('ui.echomail.ignore.removed', 'Ignore rule removed'))
                : uiT('ui.echomail.ignore.removed', 'Ignore rule removed');
            $('#settingsStatus').show().html(`
                <div class="alert alert-success">
                    <i class="fas fa-check me-2"></i>
                    ${escapeHtml(successMessage)}
                </div>
            `);
            loadEchomailIgnoreRules();
            setTimeout(function() {
                $('#settingsStatus').fadeOut();
            }, 3000);
        },
