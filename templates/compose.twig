            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-cog me-2"></i>{{ t('ui.compose.templates.manage_modal_title', {}, locale, ['common']) }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
