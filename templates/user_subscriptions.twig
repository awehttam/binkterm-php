{% extends "base.twig" %}

{% block title %}{{ t('ui.user_subscriptions.page_title', {}, locale, ['common']) }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-bookmark-star me-2"></i>
                        {{ t('ui.user_subscriptions.heading', {}, locale, ['common']) }}
                    </h5>
                    <small class="text-muted">{{ t('ui.user_subscriptions.heading_help', {}, locale, ['common']) }}</small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <div id="subscription-status" class="alert d-none" role="alert"></div>
                            
                            <div class="mb-3">
                                <input type="text" 
                                       class="form-control" 
                                       id="search-echoareas" 
                                       placeholder="{{ t('ui.user_subscriptions.search_placeholder', {}, locale, ['common']) }}">
                            </div>
                            
                            <div id="echoareas-list">
                                {% for echoarea in echoareas %}
                                <div class="card mb-3 echoarea-card" data-tag="{{ echoarea.tag|lower }}">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-1">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input subscription-toggle" 
                                                           type="checkbox" 
                                                           id="sub-{{ echoarea.id }}"
                                                           data-echoarea-id="{{ echoarea.id }}"
                                                           {{ echoarea.subscribed ? 'checked' : '' }}>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <h6 class="mb-1 d-flex align-items-center">
                                                    <span class="me-2" style="display: inline-block; width: 20px; height: 20px; min-width: 20px; min-height: 20px; background-color: {{ echoarea.color }}; border-radius: 3px; flex-shrink: 0;"></span>
                                                    <span style="color: #ffc107;">{{ echoarea.tag }}</span>
                                                    {% if echoarea.domain %}
                                                        <span class="badge bg-secondary ms-2" style="font-size: 0.7em;">{{ echoarea.domain }}</span>
                                                    {% endif %}
                                                    {% if echoarea.is_default_subscription %}
                                                        <i class="bi bi-star-fill text-warning ms-2" title="{{ t('ui.user_subscriptions.default_subscription_title', {}, locale, ['common']) }}"></i>
                                                    {% endif %}
                                                </h6>
                                            </div>
                                            <div class="col-md-5">
                                                <p class="mb-1">{{ echoarea.description }}</p>
                                                <small class="text-muted">
                                                    {{ t('ui.user_subscriptions.message_count', {'count': echoarea.message_count}, locale, ['common']) }}
                                                    {% if echoarea.subscribed %}
                                                        {{ t('ui.user_subscriptions.dot_subscribed', {}, locale, ['common']) }}
                                                        {% if echoarea.subscription_type == 'auto' %}
                                                            {{ t('ui.user_subscriptions.automatic', {}, locale, ['common']) }}
                                                        {% else %}
                                                            ({{ echoarea.subscribed_at|date('M j, Y') }})
                                                        {% endif %}
                                                    {% endif %}
                                                </small>
                                            </div>
                                            <div class="col-md-3 text-end">
                                                <a href="/echomail/{{ echoarea.tag }}@{{ echoarea.domain }}"
                                                   class="btn btn-sm {{ echoarea.subscribed ? 'btn-outline-primary' : 'btn-outline-secondary' }}">
                                                    <i class="bi bi-eye me-1"></i>
                                                    {{ t('ui.user_subscriptions.view_messages', {}, locale, ['common']) }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">
                                        <i class="bi bi-info-circle me-2"></i>
                                        {{ t('ui.user_subscriptions.subscription_info', {}, locale, ['common']) }}
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div id="subscription-stats">
                                        {% set subscribed_count = echoareas|filter(e => e.subscribed)|length %}
                                        {% set total_count = echoareas|length %}
                                        
                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between">
                                                <span>{{ t('ui.user_subscriptions.subscribed_label', {}, locale, ['common']) }}</span>
                                                <strong>{{ subscribed_count }} / {{ total_count }}</strong>
                                            </div>
                                            <div class="progress mt-1" style="height: 5px;">
                                                <div class="progress-bar" 
                                                     style="width: {{ total_count > 0 ? (subscribed_count / total_count * 100) : 0 }}%">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <hr>
                                    
                                    <h6>{{ t('ui.user_subscriptions.how_subscriptions_work', {}, locale, ['common']) }}</h6>
                                    <ul class="small text-muted mb-0">
                                        <li>{{ t('ui.user_subscriptions.how_new_users', {}, locale, ['common']) }}</li>
                                        <li>{{ t('ui.user_subscriptions.how_subscribe_unsubscribe', {}, locale, ['common']) }}</li>
                                        <li>{{ t('ui.user_subscriptions.how_only_subscribed', {}, locale, ['common']) }}</li>
                                        <li><i class="bi bi-star-fill text-warning"></i> {{ t('ui.user_subscriptions.how_star_means_default', {}, locale, ['common']) }}</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function uiT(key, fallback, params = {}) {
    if (window.t) {
        return window.t(key, params, fallback);
    }
    return fallback;
}

document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-echoareas');
    const echoareaCards = document.querySelectorAll('.echoarea-card');
    const subscriptionToggles = document.querySelectorAll('.subscription-toggle');
    const statusDiv = document.getElementById('subscription-status');
    
    // Search functionality
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        echoareaCards.forEach(card => {
            const tag = card.dataset.tag;
            const description = card.querySelector('p').textContent.toLowerCase();
            const matches = tag.includes(searchTerm) || description.includes(searchTerm);
            card.style.display = matches ? 'block' : 'none';
        });
    });
    
    // Subscription toggle functionality
    subscriptionToggles.forEach(toggle => {
        toggle.addEventListener('change', function() {
            const echoareaId = this.dataset.echoareaId;
            const action = this.checked ? 'subscribe' : 'unsubscribe';
            const originalState = !this.checked;
            
            // Disable toggle while processing
            this.disabled = true;
            
            fetch('/api/subscriptions/user', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    action: action,
                    echoarea_id: parseInt(echoareaId)
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const fallbackMessage = action === 'subscribe'
                        ? uiT('ui.user_subscriptions.subscribed_success', 'Subscribed successfully!')
                        : uiT('ui.user_subscriptions.unsubscribed_success', 'Unsubscribed successfully!');
                    const successMessage = window.getApiMessage
                        ? window.getApiMessage(data, fallbackMessage)
                        : fallbackMessage;
                    showStatus(
                        successMessage,
                        'success'
                    );
                    // Refresh page to update stats and view buttons
                    setTimeout(() => location.reload(), 1000);
                } else {
                    // Revert toggle state
                    this.checked = originalState;
                    showStatus(uiT('ui.user_subscriptions.update_failed', 'Failed to update subscription. Please try again.'), 'danger');
                }
            })
            .catch(error => {
                // Revert toggle state
                this.checked = originalState;
                showStatus(uiT('ui.user_subscriptions.network_error', 'Network error. Please try again.'), 'danger');
            })
            .finally(() => {
                this.disabled = false;
            });
        });
    });
    
    function showStatus(message, type) {
        statusDiv.className = `alert alert-${type}`;
        statusDiv.textContent = message;
        statusDiv.classList.remove('d-none');
        
        setTimeout(() => {
            statusDiv.classList.add('d-none');
        }, 3000);
    }
});
</script>
{% endblock %}
