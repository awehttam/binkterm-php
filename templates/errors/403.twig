{% extends "base.twig" %}

{% block title %}{{ t('ui.error403.title', {}, 'common') }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-secondary">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-id-card me-2"></i>
                    {{ t('ui.error403.title', {}, 'common') }}
                </h5>
            </div>
            <div class="card-body text-center py-5">
                <i class="fas fa-lock text-muted mb-4" style="font-size: 4rem; opacity: 0.5;"></i>
                <h4 class="mb-3">{{ t('ui.error403.heading', {}, 'common') }}</h4>
                <p class="text-muted mb-4">{{ t('ui.error403.description', {}, 'common') }}</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a href="/admin/licensing" class="btn btn-outline-primary">
                        <i class="fas fa-id-card me-1"></i>
                        {{ t('ui.error403.licensing_link', {}, 'common') }}
                    </a>
                    <a href="/admin" class="btn btn-secondary">
                        <i class="fas fa-home me-1"></i>
                        {{ t('ui.common.go_back', {}, 'common') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
