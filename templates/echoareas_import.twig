{% extends "base.twig" %}

{% block title %}Import Echo Areas - {{ parent() }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-file-import me-2"></i>
        Import Echo Areas
    </h2>
    <a href="/echoareas" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-1"></i>
        Back to Echo Areas
    </a>
</div>

{% if import_error %}
<div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle me-2"></i>
    {{ import_error }}
</div>
{% endif %}

{% if import_summary %}
<div class="alert alert-info">
    <div><strong>Processed:</strong> {{ import_summary.processed }}</div>
    <div><strong>Created:</strong> {{ import_summary.created }}</div>
    <div><strong>Updated:</strong> {{ import_summary.updated }}</div>
    <div><strong>Skipped blank rows:</strong> {{ import_summary.skipped }}</div>
    <div><strong>Errors:</strong> {{ import_summary.errors|length }}</div>
</div>

{% if import_summary.errors|length > 0 %}
<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Import Errors</h6>
    </div>
    <div class="card-body">
        <ul class="mb-0">
            {% for item in import_summary.errors %}
            <li>{{ item }}</li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}
{% endif %}

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Upload CSV</h5>
            </div>
            <div class="card-body">
                <form method="POST" enctype="multipart/form-data" id="echoareaImportForm">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="mb-3">
                        <label for="echoareasCsv" class="form-label">CSV File</label>
                        <input type="file" class="form-control" id="echoareasCsv" name="echoareas_csv" accept=".csv,text/csv" required>
                        <div class="form-text">UTF-8 CSV is recommended. Header row is optional.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/echoareas" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-fidonet" id="echoareaImportBtn">
                            <i class="fas fa-file-import me-1" id="echoareaImportIcon"></i>
                            <span id="echoareaImportLabel">Import Echo Areas</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">CSV Format</h6>
            </div>
            <div class="card-body">
                <p class="mb-2">Each row must contain these fields in this order:</p>
                <pre class="bg-light border rounded p-3 mb-3">ECHOTAG,DESCRIPTION,DOMAIN</pre>
                <p class="mb-2">Example:</p>
                <pre class="bg-light border rounded p-3 mb-0">FIDONET.GEN,General FidoNet discussion,fidonet
FSX_GEN,FSXnet general discussion,fsxnet
LOCAL.TEST,Local test area,</pre>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Import Rules</h6>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    <li><code>DOMAIN</code> may be blank. Blank domain imports the area as local-only.</li>
                    <li>If <code>DOMAIN</code> is provided, it must already exist in your BinkP network configuration.</li>
                    <li>If an area already exists with the same <code>ECHOTAG</code> and <code>DOMAIN</code>, its description is updated and the area is reactivated.</li>
                    <li>New areas are created active with default settings; you can fine-tune them afterward in Echo Areas Management.</li>
                    <li>Header row <code>ECHOTAG,DESCRIPTION,DOMAIN</code> is accepted but not required.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('echoareaImportForm');
    const button = document.getElementById('echoareaImportBtn');
    const icon = document.getElementById('echoareaImportIcon');
    const label = document.getElementById('echoareaImportLabel');

    form.addEventListener('submit', function() {
        button.disabled = true;
        icon.className = 'fas fa-spinner fa-spin me-1';
        label.textContent = 'Importing...';
    });
});
</script>
{% endblock %}
