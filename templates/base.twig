                                <i class="fas fa-terminal"></i> {{ t('ui.base.guest_doors', {}, 'common') }}
                            </a>
                        </li>
                        {% endif %}
                        <li class="nav-item">
                            <a class="nav-link" href="/login">{{ t('ui.base.login', {}, 'common') }}</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        {% block content %}{% endblock %}
    </main>

    <footer class="bg-light mt-5 py-3">
        <div class="container text-center">
            <small class="text-muted">
                {% if license_valid and appearance.branding.footer_text %}
                    {{ appearance.branding.footer_text | e }}
                {% else %}
                    {{ system_name }} - Node {{ fidonet_origin }} - Sysop: {{ sysop_name }}
                {% endif %}
            </small>
            <br>
            <small class="text-muted">
                {% if not (license_valid and appearance.branding.hide_powered_by) %}
                    {{ t('ui.footer.powered_by', {}, 'common') }} <a href="https://lovelybits.org/binktermphp">BinktermPHP</a> <a href="https://github.com/awehttam/binkterm-php">{{ app_version }}</a>{% if license_valid and license_system_name and appearance.branding.show_registration_badge != false %} - {{ t('ui.footer.registered_to', {'name': license_system_name}, 'common') }}{% endif %} |
                {% endif %}
                <a href="#" data-bs-toggle="modal" data-bs-target="#houseRulesModal">{{ t('ui.about.house_rules', {}, 'common') }}</a>
            </small>
        </div>
    </footer>

    <div class="modal fade" id="houseRulesModal" tabindex="-1" aria-labelledby="houseRulesModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="houseRulesModalLabel">{{ t('ui.about.house_rules', {}, 'common') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    {% include 'rules.twig' %}
                </div>
            </div>
        </div>
    </div>



    <script>
        // Global user settings loaded from server
        window.userSettings = {
            timezone: 'America/Los_Angeles' // Default, will be loaded via AJAX
        };
        {% if current_user %}
        window.currentUserId = {{ current_user.user_id ?? current_user.id }};
        window.currentUserIsAdmin = {{ current_user.is_admin ? 'true' : 'false' }};
        {% endif %}
        window.isDevMode = {{ is_dev ? 'true' : 'false' }};

        // Handle nested dropdown submenus
        $(document).ready(function() {
            // Show submenu on hover (desktop)
            $('.dropdown-submenu').hover(
                function() {
                    $(this).find('> .dropdown-menu').show();
                },
                function() {
                    $(this).find('> .dropdown-menu').hide();
                }
            );

            // Handle click on submenu toggle
            $('.dropdown-submenu > .dropdown-toggle').on('click', function(e) {
                const href = $(this).attr('href');

                // If it's a real link (not #), allow normal navigation on direct click
                if (href && href !== '#') {
                    // On mobile or if submenu is not visible, toggle submenu instead
                    if ($(window).width() <= 768 || !$(this).next('.dropdown-menu').is(':visible')) {
                        e.preventDefault();
                        e.stopPropagation();

                        const $submenu = $(this).next('.dropdown-menu');
                        $('.dropdown-submenu .dropdown-menu').not($submenu).hide();
                        $submenu.toggle();
                    }
                    // Otherwise let the link work normally
                } else {
                    // For # links, just toggle submenu
                    e.preventDefault();
                    e.stopPropagation();

                    const $submenu = $(this).next('.dropdown-menu');
                    $('.dropdown-submenu .dropdown-menu').not($submenu).hide();
                    $submenu.toggle();
                }
            });

            // Hide submenu when parent dropdown closes
            $('.dropdown').on('hide.bs.dropdown', function() {
                $(this).find('.dropdown-submenu .dropdown-menu').hide();
            });
        });
    </script>
    <script>
        if ('serviceWorker' in navigator) {
            let updateNotified = false;

            function showUpdateToast() {
                if (updateNotified) return;
                updateNotified = true;
                const toastEl = document.getElementById('updateToast');
                if (toastEl && window.bootstrap) {
                    bootstrap.Toast.getOrCreateInstance(toastEl).show();
                }
            }

            // Path 1: SW sends UPDATE_AVAILABLE after activate + clients.claim().
            navigator.serviceWorker.addEventListener('message', (event) => {
                if (event.data && event.data.type === 'UPDATE_AVAILABLE') {
                    showUpdateToast();
                }
            });

            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(registration => {
                        // Path 1 (postMessage from SW) is the only notification mechanism.
                        // Path 2 (watchWorker statechange) was removed: it fired on every
                        // navigation where the browser detected a SW update and the new SW
                        // activated, causing a spurious reload prompt as the user navigated
                        // away.  Path 1 is sufficient — the SW already gates UPDATE_AVAILABLE
                        // on replacedOld (old caches were purged), so it only fires for real
                        // version upgrades on pages that were open before the update landed.
                        registration.update();
                        setInterval(() => registration.update(), 60000);
                    })
                    .catch(err => {
                        console.warn('[SW] Registration failed:', err);
                    });
            });
        }

        function activateUpdate() {
            // The SW already activated via skipWaiting() during install.
            // A plain reload is all that is needed to pick up the new cached assets.
            window.location.reload();
        }
    </script>

    
    {% block scripts %}{% endblock %}
</body>
</html>
