{% extends "base.twig" %}

{% block title %}{{ t('ui.guest_doors.page_title', {}, 'common') }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card mb-3">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="fas fa-terminal"></i>
                    {{ t('ui.guest_doors.heading', {}, 'common') }}
                </h4>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">{{ t('ui.guest_doors.subtitle', {}, 'common') }}</p>

                {% if doors is empty %}
                    <p class="text-muted text-center py-3">{{ t('ui.guest_doors.no_doors', {}, 'common') }}</p>
                {% else %}
                    <div class="list-group">
                        {% for door in doors %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>{{ door.name }}</strong>
                                    {% if door.description %}
                                    <div class="text-muted small">{{ door.description }}</div>
                                    {% endif %}
                                </div>
                                <a href="/play/{{ door.door_id }}" target="_blank" class="btn btn-outline-secondary btn-sm ms-3 text-nowrap">
                                    <i class="fas fa-terminal"></i>
                                    {{ t('ui.guest_doors.connect', {}, 'common') }}
                                </a>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="text-center">
            <small class="text-muted">
                <a href="/login" class="text-decoration-none">{{ t('ui.guest_doors.signin_link', {}, 'common') }}</a> or
                <a href="/register" class="text-decoration-none">{{ t('ui.guest_doors.register_link', {}, 'common') }}</a> for full access.
            </small>
        </div>
    </div>
</div>
{% endblock %}
