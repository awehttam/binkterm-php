{% extends "base.twig" %}

{% block title %}{{ t('ui.admin.auto_feed.page_title') }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-rss"></i>
        {{ t('ui.admin.auto_feed.heading') }}
    </h2>
    <button class="btn btn-fidonet" onclick="showAddFeedModal()">
        <i class="fas fa-plus"></i>
        {{ t('ui.admin.auto_feed.add_feed') }}
    </button>
</div>

<div class="row">
    <div class="col-lg-9">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">{{ t('ui.admin.auto_feed.feed_sources') }}</h6>
            </div>
            <div class="card-body p-0">
                <div id="feedsContainer">
                    <div class="loading-spinner">
                        <i class="fas fa-spinner fa-spin me-2"></i>
                        {{ t('ui.admin.auto_feed.loading_feeds') }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">{{ t('ui.admin.auto_feed.statistics') }}</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-8">{{ t('ui.admin.auto_feed.total_feeds') }}:</dt>
                    <dd class="col-4" id="totalFeeds">-</dd>

                    <dt class="col-8">{{ t('ui.admin.auto_feed.active_label') }}:</dt>
                    <dd class="col-4" id="activeFeeds">-</dd>

                    <dt class="col-8">{{ t('ui.admin.auto_feed.articles_posted') }}:</dt>
                    <dd class="col-4" id="totalArticles">-</dd>
                </dl>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">{{ t('ui.admin.auto_feed.about_title') }}</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">
                    {{ t('ui.admin.auto_feed.about_text') }}
                </p>
                <p class="small text-muted mb-0">
                    {{ t('ui.admin.auto_feed.cron_hint_prefix') }} <code>php scripts/rss_poster.php</code> {{ t('ui.admin.auto_feed.cron_hint_suffix') }}
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Feed Modal -->
<div class="modal fade" id="feedModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="feedModalTitle">{{ t('ui.admin.auto_feed.add_feed') }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="feedForm">
                    <input type="hidden" id="feedId">

                    <div class="mb-3">
                        <label for="feedName" class="form-label">{{ t('ui.admin.auto_feed.feed_name') }}</label>
                        <input type="text" class="form-control" id="feedName" name="feed_name" maxlength="100" placeholder="{{ t('ui.admin.auto_feed.feed_name_placeholder') }}">
                        <div class="form-text">{{ t('ui.admin.auto_feed.feed_name_help') }}</div>
                    </div>

                    <div class="mb-3">
                        <label for="feedUrl" class="form-label">{{ t('ui.admin.auto_feed.feed_url_required') }}</label>
                        <input type="url" class="form-control" id="feedUrl" name="feed_url" required placeholder="{{ t('ui.admin.auto_feed.feed_url_placeholder', {}, locale, ['common']) }}">
                        <div class="form-text">{{ t('ui.admin.auto_feed.feed_url_help') }}</div>
                    </div>

                    <div class="mb-3">
                        <label for="feedSourceType" class="form-label">{{ t('ui.admin.auto_feed.source_type') }}</label>
                        <select class="form-select" id="feedSourceType" name="source_type">
                            <option value="rss">{{ t('ui.admin.auto_feed.source_type_rss') }}</option>
                            <option value="bluesky">{{ t('ui.admin.auto_feed.source_type_bluesky') }}</option>
                        </select>
                        <div class="form-text">{{ t('ui.admin.auto_feed.source_type_help') }}</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">{{ t('ui.admin.auto_feed.echo_areas_required') }}</label>
                        <input type="text" class="form-control mb-2" id="feedEchoareaSearch" placeholder="{{ t('ui.admin.auto_feed.echoarea_search_placeholder') }}">
                        <div id="feedEchoareaList" style="max-height:220px;overflow-y:auto;border:1px solid var(--bs-border-color);border-radius:0.375rem;padding:0.5rem;">
                            <div class="text-muted small">{{ t('ui.admin.auto_feed.loading_echo_areas') }}</div>
                        </div>
                        <div class="form-text">{{ t('ui.admin.auto_feed.echo_areas_help') }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label for="feedPosterName" class="form-label">{{ t('ui.admin.auto_feed.poster_name_required') }}</label>
                            <input type="text" class="form-control" id="feedPosterName" name="poster_name" maxlength="100" required placeholder="{{ t('ui.admin.auto_feed.poster_name_placeholder') }}">
                            <div class="form-text">{{ t('ui.admin.auto_feed.poster_name_help') }}</div>
                        </div>
                        <div class="col-md-4">
                            <label for="feedMaxArticles" class="form-label">{{ t('ui.admin.auto_feed.max_articles') }}</label>
                            <input type="number" class="form-control" id="feedMaxArticles" name="max_articles_per_check" value="10" min="1" max="50">
                            <div class="form-text">{{ t('ui.admin.auto_feed.per_check') }}</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="feedThreadReplies" name="thread_replies">
                                <label class="form-check-label fw-semibold" for="feedThreadReplies">
                                    {{ t('ui.admin.auto_feed.thread_replies') }}
                                </label>
                                <div class="form-text">{{ t('ui.admin.auto_feed.thread_replies_help') }}</div>
                            </div>
                        </div>
                        <div class="col-md-4" id="threadLookupLimitGroup" style="display:none;">
                            <label for="feedThreadLookupLimit" class="form-label">{{ t('ui.admin.auto_feed.thread_lookup_limit') }}</label>
                            <input type="number" class="form-control" id="feedThreadLookupLimit" name="thread_lookup_limit" value="1000" min="100" max="10000">
                            <div class="form-text">{{ t('ui.admin.auto_feed.thread_lookup_limit_help') }}</div>
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="feedIncludeNameInSubject" name="include_feed_name_in_subject">
                        <label class="form-check-label fw-semibold" for="feedIncludeNameInSubject">
                            {{ t('ui.admin.auto_feed.include_feed_name_in_subject') }}
                        </label>
                        <div class="form-text">{{ t('ui.admin.auto_feed.include_feed_name_in_subject_help') }}</div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="feedActive" name="active" checked>
                        <label class="form-check-label" for="feedActive">
                            {{ t('ui.admin.auto_feed.active_label') }}
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('ui.common.cancel') }}</button>
                <button type="button" class="btn btn-fidonet" onclick="saveFeed()">
                    <i class="fas fa-save"></i>
                    {{ t('ui.common.save') }}
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ t('ui.admin.auto_feed.confirm_delete_title') }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>{{ t('ui.admin.auto_feed.confirm_delete_text_prefix') }} <strong id="deleteFeedName"></strong>?</p>
                <p class="text-warning"><i class="fas fa-exclamation-triangle"></i> {{ t('ui.admin.auto_feed.confirm_delete_warning') }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('ui.common.cancel') }}</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">
                    <i class="fas fa-trash"></i>
                    {{ t('ui.common.delete') }}
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Check Output Modal -->
<div class="modal fade" id="checkOutputModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ t('ui.admin.auto_feed.check_output_title') }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="small text-muted mb-3" id="checkOutputSummary"></p>
                <pre id="checkOutputText" class="bg-light border rounded p-3 mb-0" style="white-space: pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('ui.common.close') }}</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
let currentFeedId = null;
let allFeeds = [];
let autoFeedEchoareas = [];
let selectedFeedEchoareaIds = new Set();

function uiT(key, fallback, params = {}) {
    if (window.t) {
        return window.t(key, params, fallback);
    }
    return fallback;
}

$(document).ready(function() {
    const initAutoFeedPage = function() {
        loadFeeds();
        loadStats();
        loadEchoareas();

        $('#feedUrl').on('input', function() {
            if (/^https?:\/\/(www\.)?bsky\.app\/profile\//i.test($(this).val())) {
                $('#feedSourceType').val('bluesky');
            }
        });

        $('#feedThreadReplies').on('change', function() {
            $('#threadLookupLimitGroup').toggle($(this).is(':checked'));
        });

        $('#feedEchoareaSearch').on('input', function() {
            renderFeedEchoareaPicker($(this).val().toLowerCase());
        });
    };

    if (typeof loadUserSettings === 'function') {
        loadUserSettings().finally(initAutoFeedPage);
        return;
    }

    initAutoFeedPage();
});

function loadFeeds() {
    $('#feedsContainer').html(`<div class="loading-spinner"><i class="fas fa-spinner fa-spin me-2"></i>${uiT('ui.admin.auto_feed.loading_feeds', 'Loading feeds...')}</div>`);

    $.get('/admin/api/auto-feed/feeds')
        .done(function(data) {
            console.log('API response:', data);
            if (!data || !data.feeds) {
                console.error('Invalid response structure:', data);
                $('#feedsContainer').html(`<div class="text-center text-danger py-4">${uiT('ui.admin.auto_feed.invalid_api_response', 'Invalid API response')}</div>`);
                return;
            }
            allFeeds = data.feeds;
            displayFeeds(allFeeds);
        })
        .fail(function(xhr, status, error) {
            console.error('API error:', status, error);
            $('#feedsContainer').html(`<div class="text-center text-danger py-4">${uiT('ui.admin.auto_feed.failed_to_load_feeds_prefix', 'Failed to load feeds:')} ${escapeHtml(error)}</div>`);
        });
}

function displayFeeds(feeds) {
    const container = $('#feedsContainer');
    let html = '';

    if (feeds.length === 0) {
        html = `<div class="text-center text-muted py-4">${uiT('ui.admin.auto_feed.no_feeds_configured', 'No feeds configured')}</div>`;
    } else {
        html = `
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th width="5%"></th>
                            <th width="18%">${uiT('ui.admin.auto_feed.name_url', 'Name/URL')}</th>
                            <th width="10%">${uiT('ui.admin.auto_feed.source_type', 'Source Type')}</th>
                            <th width="20%">${uiT('ui.admin.auto_feed.echo_areas', 'Echo Areas')}</th>
                            <th width="14%">${uiT('ui.admin.auto_feed.poster_name', 'Poster Name')}</th>
                            <th width="10%">${uiT('ui.admin.auto_feed.articles', 'Articles')}</th>
                            <th width="15%">${uiT('ui.admin.auto_feed.last_check', 'Last Check')}</th>
                            <th width="10%">${uiT('ui.admin.auto_feed.actions', 'Actions')}</th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        feeds.forEach(function(feed) {
            const isActive = feed.active;
            const rowClass = isActive ? '' : 'table-secondary';
            const statusIcon = isActive ?
                `<i class="fas fa-check-circle text-success" title="${uiT('ui.admin.auto_feed.active_label', 'Active')}"></i>` :
                `<i class="fas fa-pause-circle text-warning" title="${uiT('ui.admin.auto_feed.inactive_label', 'Inactive')}"></i>`;

            const lastCheck = feed.last_check ?
                new Date(feed.last_check).toLocaleString() :
                `<span class="text-muted">${uiT('ui.admin.auto_feed.never', 'Never')}</span>`;

            const feedName = escapeHtml(feed.feed_name || uiT('ui.admin.auto_feed.unnamed_feed', 'Unnamed Feed'));
            const feedUrl = escapeHtml(feed.feed_url);
            const truncatedUrl = feedUrl.length > 50 ? feedUrl.substring(0, 47) + '...' : feedUrl;
            const echoareas = Array.isArray(feed.echoareas) ? feed.echoareas : [];

            html += `
                <tr class="${rowClass}">
                    <td class="text-center">${statusIcon}</td>
                    <td>
                        <strong>${feedName}</strong><br>
                        <small class="text-muted" title="${feedUrl}">${truncatedUrl}</small>
                        ${feed.last_error ? `<br><small class="text-danger"><i class="fas fa-exclamation-triangle"></i> ${uiT('ui.common.error', 'Error')}</small>` : ''}
                    </td>
                    <td>
                        <span class="badge bg-secondary">${formatSourceType(feed.source_type || 'rss')}</span>
                    </td>
                    <td>
                        ${renderFeedEchoareas(echoareas)}
                    </td>
                    <td>
                        <small>${escapeHtml(feed.poster_name || uiT('ui.admin.auto_feed.unknown', 'Unknown'))}</small>
                    </td>
                    <td>
                        <span class="badge bg-secondary">${feed.articles_posted || 0}</span>
                    </td>
                    <td>
                        <small>${lastCheck}</small>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-outline-success" onclick="checkFeed(${feed.id})" title="${uiT('ui.admin.auto_feed.check_now', 'Check now')}">
                                <i class="fas fa-sync"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary" onclick="editFeed(${feed.id})" title="${uiT('ui.common.edit', 'Edit')}">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="showDeleteModal(${feed.id}, '${escapeHtml(feedName)}')" title="${uiT('ui.common.delete', 'Delete')}">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });

        html += `
                    </tbody>
                </table>
            </div>
        `;
    }

    container.html(html);
}

function showAddFeedModal() {
    currentFeedId = null;
    $('#feedModalTitle').text(uiT('ui.admin.auto_feed.add_feed', 'Add Feed'));
    $('#feedForm')[0].reset();
    $('#feedId').val('');
    $('#feedActive').prop('checked', true);
    $('#feedMaxArticles').val(10);
    $('#feedSourceType').val('rss');
    $('#feedThreadReplies').prop('checked', false);
    $('#feedThreadLookupLimit').val(1000);
    $('#threadLookupLimitGroup').hide();
    $('#feedIncludeNameInSubject').prop('checked', false);
    $('#feedPosterName').val('');
    $('#feedEchoareaSearch').val('');
    setSelectedEchoareas([]);
    $('#feedModal').modal('show');
}

function editFeed(id) {
    currentFeedId = id;
    $('#feedModalTitle').text(uiT('ui.admin.auto_feed.edit_feed', 'Edit Feed'));

    $.get(`/admin/api/auto-feed/feeds/${id}`)
        .done(function(data) {
            const feed = data.feed;

            $('#feedName').val(feed.feed_name || '');
            $('#feedUrl').val(feed.feed_url);
            $('#feedSourceType').val(feed.source_type || 'rss');
            $('#feedPosterName').val(feed.poster_name || '');
            $('#feedEchoareaSearch').val('');
            setSelectedEchoareas(feed.echoarea_ids || []);
            $('#feedMaxArticles').val(feed.max_articles_per_check || 10);
            $('#feedActive').prop('checked', feed.active);
            const threadReplies = !!feed.thread_replies;
            $('#feedThreadReplies').prop('checked', threadReplies);
            $('#feedThreadLookupLimit').val(feed.thread_lookup_limit || 1000);
            $('#threadLookupLimitGroup').toggle(threadReplies);
            $('#feedIncludeNameInSubject').prop('checked', !!feed.include_feed_name_in_subject);
            $('#feedModal').modal('show');
        })
        .fail(function() {
            showError(uiT('ui.admin.auto_feed.load_details_failed', 'Failed to load feed details'));
        });
}

function saveFeed() {
    const form = $('#feedForm');
    if (!form[0].checkValidity()) {
        form[0].reportValidity();
        return;
    }

    const echoareaIds = getSelectedEchoareaIds();
    if (!echoareaIds.length) {
        showError(uiT('ui.admin.auto_feed.select_echoareas', 'Select at least one echo area'));
        return;
    }

    const formData = {
        feed_name: $('#feedName').val() || null,
        feed_url: $('#feedUrl').val(),
        source_type: $('#feedSourceType').val() || 'rss',
        echoarea_ids: echoareaIds,
        poster_name: $('#feedPosterName').val().trim(),
        max_articles_per_check: parseInt($('#feedMaxArticles').val()),
        active: $('#feedActive').is(':checked'),
        thread_replies: $('#feedThreadReplies').is(':checked'),
        thread_lookup_limit: parseInt($('#feedThreadLookupLimit').val()) || 1000,
        include_feed_name_in_subject: $('#feedIncludeNameInSubject').is(':checked')
    };

    const url = currentFeedId ? `/admin/api/auto-feed/feeds/${currentFeedId}` : '/admin/api/auto-feed/feeds';
    const method = currentFeedId ? 'PUT' : 'POST';

    $.ajax({
        url: url,
        method: method,
        contentType: 'application/json',
        data: JSON.stringify(formData),
        success: function(response) {
            $('#feedModal').modal('hide');
            const defaultMessage = currentFeedId
                ? uiT('ui.admin.auto_feed.updated_success', 'Feed updated successfully')
                : uiT('ui.admin.auto_feed.created_success', 'Feed created successfully');
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, defaultMessage)
                : defaultMessage;
            showSuccess(successMessage);
            loadFeeds();
            loadStats();
        },
        error: function(xhr) {
            const error = apiError(xhr.responseJSON, uiT('ui.admin.auto_feed.operation_failed', 'Operation failed'));
            showError(error);
        }
    });
}

function showDeleteModal(id, name) {
    currentFeedId = id;
    $('#deleteFeedName').text(name);
    $('#deleteModal').modal('show');

    $('#confirmDelete').off('click').on('click', function() {
        deleteFeed();
    });
}

function deleteFeed() {
    $.ajax({
        url: `/admin/api/auto-feed/feeds/${currentFeedId}`,
        method: 'DELETE',
        success: function(response) {
            $('#deleteModal').modal('hide');
            const successMessage = window.getApiMessage
                ? window.getApiMessage(response, uiT('ui.admin.auto_feed.deleted_success', 'Feed deleted successfully'))
                : uiT('ui.admin.auto_feed.deleted_success', 'Feed deleted successfully');
            showSuccess(successMessage);
            loadFeeds();
            loadStats();
        },
        error: function(xhr) {
            const error = apiError(xhr.responseJSON, uiT('ui.admin.auto_feed.delete_failed', 'Delete failed'));
            showError(error);
        }
    });
}

function checkFeed(id) {
    const checkingMessage = uiT('ui.admin.auto_feed.checking_feed', 'Checking feed...');
    if (typeof showSuccess === 'function') {
        showSuccess(checkingMessage);
    } else {
        console.info(checkingMessage);
    }

    $.post(`/admin/api/auto-feed/check/${id}`)
        .done(function(data) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(data, uiT('ui.admin.auto_feed.checked_articles_posted', 'Feed checked: {count} new article(s) posted', { count: data.articles_posted }))
                : uiT('ui.admin.auto_feed.checked_articles_posted', 'Feed checked: {count} new article(s) posted', { count: data.articles_posted });
            showSuccess(successMessage);
            showCheckOutput(successMessage, combineCommandOutput(data));
            loadFeeds();
            loadStats();
        })
        .fail(function(xhr) {
            const error = apiError(xhr.responseJSON, uiT('ui.admin.auto_feed.check_failed', 'Check failed'));
            showError(error);
            const output = combineCommandOutput(xhr.responseJSON || {});
            if (output) {
                showCheckOutput(error, output);
            }
        });
}

function combineCommandOutput(payload) {
    if (!payload || typeof payload !== 'object') {
        return '';
    }

    const parts = [];
    if (typeof payload.detail === 'string' && payload.detail.trim() !== '') {
        parts.push(payload.detail.trim());
    }
    if (typeof payload.stdout === 'string' && payload.stdout.trim() !== '') {
        parts.push(payload.stdout.trim());
    }
    if (typeof payload.stderr === 'string' && payload.stderr.trim() !== '') {
        parts.push(payload.stderr.trim());
    }
    if (!parts.length && typeof payload.output === 'string' && payload.output.trim() !== '') {
        parts.push(payload.output.trim());
    }

    return parts.join('\n\n');
}

function showCheckOutput(summary, output) {
    $('#checkOutputSummary').text(summary || '');
    $('#checkOutputText').text(output || uiT('ui.admin.auto_feed.no_check_output', 'No output was returned.'));
    $('#checkOutputModal').modal('show');
}

function loadStats() {
    $.get('/admin/api/auto-feed/stats')
        .done(function(data) {
            $('#totalFeeds').text(data.total_feeds || 0);
            $('#activeFeeds').text(data.active_feeds || 0);
            $('#totalArticles').text(data.total_articles || 0);
        });
}

function loadEchoareas() {
    $.get('/api/echoareas')
        .done(function(data) {
            autoFeedEchoareas = Array.isArray(data.echoareas) ? data.echoareas : [];
            renderFeedEchoareaPicker($('#feedEchoareaSearch').val().toLowerCase());
        });
}

function apiError(payload, fallback) {
    if (window.getApiErrorMessage) {
        return window.getApiErrorMessage(payload, fallback);
    }
    if (payload && payload.error) {
        return String(payload.error);
    }
    return fallback;
}

function formatSourceType(sourceType) {
    if (sourceType === 'bluesky') {
        return uiT('ui.admin.auto_feed.source_type_bluesky', 'Bluesky');
    }
    return uiT('ui.admin.auto_feed.source_type_rss', 'RSS/Atom');
}

function renderFeedEchoareas(echoareas) {
    if (!echoareas.length) {
        return `<small class="text-muted">${uiT('ui.admin.auto_feed.no_echoareas', 'No echo areas')}</small>`;
    }

    return echoareas.map(function(area) {
        const domainLabel = area.is_local
            ? uiT('ui.admin.auto_feed.local_domain_label', 'Local')
            : (area.domain || uiT('ui.admin.auto_feed.unknown', 'Unknown'));
        return `<div><span class="font-monospace">${escapeHtml(area.tag || uiT('ui.admin.auto_feed.unknown', 'Unknown'))}</span><br><small class="text-muted">@ ${escapeHtml(domainLabel)}</small></div>`;
    }).join('<div class="my-1"></div>');
}

function getSelectedEchoareaIds() {
    return Array.from(selectedFeedEchoareaIds);
}

function setSelectedEchoareas(echoareaIds) {
    const normalized = Array.isArray(echoareaIds) ? echoareaIds.map(function(value) {
        return parseInt(value, 10);
    }).filter(function(value) {
        return Number.isInteger(value) && value > 0;
    }) : [];
    selectedFeedEchoareaIds = new Set(normalized);
    renderFeedEchoareaPicker($('#feedEchoareaSearch').val().toLowerCase());
}

function groupFeedEchoareasByNetwork(areas) {
    const groups = new Map();
    areas.forEach(function(area) {
        const network = area.is_local
            ? uiT('ui.admin.auto_feed.local_domain_label', 'Local')
            : ((area.domain || '').trim() ? area.domain.trim().toUpperCase() : uiT('ui.admin.auto_feed.unknown', 'Unknown'));
        if (!groups.has(network)) {
            groups.set(network, []);
        }
        groups.get(network).push(area);
    });

    return new Map(Array.from(groups.entries()).sort(function(a, b) {
        const localLabel = uiT('ui.admin.auto_feed.local_domain_label', 'Local');
        if (a[0] === localLabel) return 1;
        if (b[0] === localLabel) return -1;
        return a[0].localeCompare(b[0]);
    }));
}

function renderFeedEchoareaPicker(filter) {
    const container = document.getElementById('feedEchoareaList');
    if (!container) {
        return;
    }

    const filtered = autoFeedEchoareas.filter(function(area) {
        return !filter
            || (area.tag || '').toLowerCase().includes(filter)
            || (area.description || '').toLowerCase().includes(filter)
            || (area.domain || '').toLowerCase().includes(filter);
    });

    if (!filtered.length) {
        container.innerHTML = `<div class="text-muted small">${uiT('ui.admin.auto_feed.no_matching_echoareas', 'No matching echo areas')}</div>`;
        return;
    }

    const groups = groupFeedEchoareasByNetwork(filtered);
    let html = '';
    groups.forEach(function(networkAreas, network) {
        html += `<p class="mb-1 mt-2 fw-semibold small text-uppercase text-muted" style="letter-spacing:.05em">${escapeHtml(network)}</p>`;
        html += networkAreas.map(function(area) {
            const checked = selectedFeedEchoareaIds.has(parseInt(area.id, 10)) ? 'checked' : '';
            const description = area.description ? ' - ' + escapeHtml(area.description) : '';
            return `<div class="form-check">
                <input class="form-check-input feed-echoarea-check" type="checkbox" value="${area.id}" id="feed_ea_${area.id}" ${checked}>
                <label class="form-check-label small" for="feed_ea_${area.id}">
                    <strong>${escapeHtml(area.tag || uiT('ui.admin.auto_feed.unknown', 'Unknown'))}</strong>${description}
                </label>
            </div>`;
        }).join('');
    });

    container.innerHTML = html;
    container.querySelectorAll('.feed-echoarea-check').forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
            const id = parseInt(checkbox.value, 10);
            if (!Number.isInteger(id) || id <= 0) {
                return;
            }

            if (checkbox.checked) {
                selectedFeedEchoareaIds.add(id);
            } else {
                selectedFeedEchoareaIds.delete(id);
            }
        });
    });
}
</script>
{% endblock %}
