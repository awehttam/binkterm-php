{% extends "base.twig" %}

{% block title %}{{ t('ui.admin.bbs_settings.page_title', {}, locale, ['common']) }}{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">{{ t('ui.admin.bbs_settings.heading', {}, locale, ['common']) }}</h1>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h6 class="mb-0">{{ t('ui.admin.bbs_settings.system.title', {}, locale, ['common']) }}</h6>
                </div>
                <div class="card-body">
                    <div id="bbsSystemAlert"></div>
                    <form id="bbsSystemForm">
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemName">{{ t('ui.admin.bbs_settings.system.system_name', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="bbsSystemName">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemSysop">{{ t('ui.admin.bbs_settings.system.sysop_name', {}, locale, ['common']) }}</label>
                            <select class="form-select" id="bbsSystemSysop"></select>
                            <small class="text-muted">{{ t('ui.admin.bbs_settings.system.select_admin_user', {}, locale, ['common']) }}</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemLocation">{{ t('ui.admin.bbs_settings.system.location', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="bbsSystemLocation">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemTimezone">{{ t('ui.admin.bbs_settings.system.timezone', {}, locale, ['common']) }}</label>
                            <select class="form-select" id="bbsSystemTimezone">
                                {% for tz in timezone_list %}
                                    <option value="{{ tz }}">{{ tz }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemAddress">{{ t('ui.admin.bbs_settings.system.system_address', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="bbsSystemAddress">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsSystemOrigin">{{ t('ui.admin.bbs_settings.system.origin_line', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="bbsSystemOrigin">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="saveBbsSystem()">{{ t('ui.admin.bbs_settings.system.save', {}, locale, ['common']) }}</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h6 class="mb-0">{{ t('ui.admin.bbs_settings.features.title', {}, locale, ['common']) }}</h6>
                </div>
                <div class="card-body">
                    <div id="bbsSettingsAlert"></div>
                    <form id="bbsSettingsForm">
                        <div class="form-check mb-2 d-flex align-items-center gap-2">
                            <input class="form-check-input" type="checkbox" id="bbsWebdoors">
                            <label class="form-check-label" for="bbsWebdoors">{{ t('ui.admin.bbs_settings.features.enable_webdoors', {}, locale, ['common']) }}</label>
                            {% if not webdoors_active %}
                                <small class="text-muted">
                                    ({{ t('ui.admin.bbs_settings.features.inactive', {}, locale, ['common']) }})
                                    <a href="/admin/webdoors" class="ms-1">{{ t('ui.admin.bbs_settings.features.activate', {}, locale, ['common']) }}</a>
                                </small>
                            {% endif %}
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="bbsShoutbox">
                            <label class="form-check-label" for="bbsShoutbox">{{ t('ui.admin.bbs_settings.features.enable_shoutbox', {}, locale, ['common']) }}</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="bbsAdvertising">
                            <label class="form-check-label" for="bbsAdvertising">{{ t('ui.admin.bbs_settings.features.enable_advertising', {}, locale, ['common']) }}</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="bbsVoting">
                            <label class="form-check-label" for="bbsVoting">{{ t('ui.admin.bbs_settings.features.enable_voting_booth', {}, locale, ['common']) }}</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="bbsChat">
                            <label class="form-check-label" for="bbsChat">{{ t('ui.admin.bbs_settings.features.enable_chat', {}, locale, ['common']) }}</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="bbsFileAreas">
                            <label class="form-check-label" for="bbsFileAreas">{{ t('ui.admin.bbs_settings.features.enable_file_areas', {}, locale, ['common']) }}</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bbsDefaultEchoInterface">{{ t('ui.admin.bbs_settings.features.default_echo_interface', {}, locale, ['common']) }}</label>
                            <select class="form-select" id="bbsDefaultEchoInterface">
                                <option value="echolist">{{ t('ui.admin.bbs_settings.features.echo_list_forum', {}, locale, ['common']) }}</option>
                                <option value="reader">{{ t('ui.admin.bbs_settings.features.reader_message_list', {}, locale, ['common']) }}</option>
                            </select>
                            <small class="text-muted">{{ t('ui.admin.bbs_settings.features.default_echo_help', {}, locale, ['common']) }}</small>
                        </div>
                        <hr>
                        <div class="mb-3">
                            <label class="form-label" for="bbsMaxCrossPost">{{ t('ui.admin.bbs_settings.features.max_cross_post_areas', {}, locale, ['common']) }}</label>
                            <input type="number" class="form-control" id="bbsMaxCrossPost" min="2" max="20" step="1" value="5">
                            <small class="text-muted">{{ t('ui.admin.bbs_settings.features.max_cross_post_help', {}, locale, ['common']) }}</small>
                        </div>
                        <button type="button" class="btn btn-primary" onclick="saveBbsSettings()">{{ t('ui.admin.bbs_settings.features.save', {}, locale, ['common']) }}</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h6 class="mb-0">{{ t('ui.admin.bbs_settings.credits.title', {}, locale, ['common']) }}</h6>
                </div>
                <div class="card-body">
                    <div id="bbsCreditsAlert"></div>
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" id="bbsCreditsEnabled">
                                <label class="form-check-label" for="bbsCreditsEnabled">{{ t('ui.admin.bbs_settings.credits.enabled', {}, locale, ['common']) }}</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsSymbol">{{ t('ui.admin.bbs_settings.credits.currency_symbol', {}, locale, ['common']) }}</label>
                                <input type="text" class="form-control" id="bbsCreditsSymbol" maxlength="5">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.currency_symbol_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsDailyAmount">{{ t('ui.admin.bbs_settings.credits.daily_login_bonus_amount', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsDailyAmount" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.daily_login_bonus_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsDailyDelay">{{ t('ui.admin.bbs_settings.credits.daily_login_delay_minutes', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsDailyDelay" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.daily_login_delay_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsApprovalBonus">{{ t('ui.admin.bbs_settings.credits.new_user_approval_bonus', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsApprovalBonus" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.new_user_approval_bonus_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsNew14Days">{{ t('ui.admin.bbs_settings.credits.new_user_14_day_bonus', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsNew14Days" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.new_user_14_day_bonus_help', {}, locale, ['common']) }}</small>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsNetmailCost">{{ t('ui.admin.bbs_settings.credits.netmail_cost', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsNetmailCost" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.netmail_cost_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsEchomailReward">{{ t('ui.admin.bbs_settings.credits.echomail_reward', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsEchomailReward" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.echomail_reward_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsCrashmailCost">{{ t('ui.admin.bbs_settings.credits.crashmail_cost', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsCrashmailCost" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.crashmail_cost_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsPollCreationCost">{{ t('ui.admin.bbs_settings.credits.poll_creation_cost', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsPollCreationCost" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.poll_creation_cost_help', {}, locale, ['common']) }}</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsTransferFee">{{ t('ui.admin.bbs_settings.credits.transfer_fee_percentage', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsTransferFee" min="0" max="1" step="0.01">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.transfer_fee_help', {}, locale, ['common']) }}</small>
                            </div>
                            <hr>
                            <h6 class="mb-3">{{ t('ui.admin.bbs_settings.credits.referral_system', {}, locale, ['common']) }}</h6>
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" id="bbsCreditsReferralEnabled">
                                <label class="form-check-label" for="bbsCreditsReferralEnabled">{{ t('ui.admin.bbs_settings.credits.enable_referral_system', {}, locale, ['common']) }}</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="bbsCreditsReferralBonus">{{ t('ui.admin.bbs_settings.credits.referral_bonus', {}, locale, ['common']) }}</label>
                                <input type="number" class="form-control" id="bbsCreditsReferralBonus" min="0" step="1">
                                <small class="text-muted">{{ t('ui.admin.bbs_settings.credits.referral_bonus_help', {}, locale, ['common']) }}</small>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-primary" onclick="saveBbsCredits()">{{ t('ui.admin.bbs_settings.credits.save', {}, locale, ['common']) }}</button>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h6 class="mb-0">{{ t('ui.admin.bbs_settings.taglines.title', {}, locale, ['common']) }}</h6>
                </div>
                <div class="card-body">
                    <div id="bbsTaglinesAlert"></div>
                    <div class="mb-3">
                        <label class="form-label" for="bbsTaglinesText">{{ t('ui.admin.bbs_settings.taglines.one_per_line', {}, locale, ['common']) }}</label>
                        <textarea class="form-control" id="bbsTaglinesText" rows="8" placeholder="{{ t('ui.admin.bbs_settings.taglines.placeholder', {}, locale, ['common']) }}"></textarea>
                        <small class="text-muted">{{ t('ui.admin.bbs_settings.taglines.help', {}, locale, ['common']) }}</small>
                    </div>
                    <button type="button" class="btn btn-primary" onclick="saveBbsTaglines()">{{ t('ui.admin.bbs_settings.taglines.save', {}, locale, ['common']) }}</button>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script>
function uiT(key, fallback, params = {}) {
    if (window.t) {
        return window.t(key, params, fallback);
    }
    return fallback;
}

document.addEventListener('DOMContentLoaded', function() {
    loadBbsSettings();
    loadBbsSystem();
    loadAdminUsers('bbsSystemSysop');
    loadBbsTaglines();
});

function loadBbsSettings() {
    fetch('/admin/api/bbs-settings')
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                throw new Error(apiError(data, uiT('ui.admin.bbs_settings.load_failed', 'Failed to load settings')));
            }
            const features = data.config?.features || {};
            const credits = data.config?.credits || {};
            document.getElementById('bbsWebdoors').checked = !!features.webdoors;
            document.getElementById('bbsShoutbox').checked = !!features.shoutbox;
            document.getElementById('bbsAdvertising').checked = !!features.advertising;
            document.getElementById('bbsVoting').checked = !!features.voting_booth;
            document.getElementById('bbsChat').checked = !!features.chat;
            document.getElementById('bbsFileAreas').checked = !!features.file_areas;
            document.getElementById('bbsDefaultEchoInterface').value = data.config?.default_echo_interface || 'echolist';
            const maxCrossPost = parseInt(data.config?.max_cross_post_areas, 10);
            document.getElementById('bbsMaxCrossPost').value = Number.isNaN(maxCrossPost) ? 5 : maxCrossPost;
            document.getElementById('bbsCreditsEnabled').checked = credits.enabled !== false;
            document.getElementById('bbsCreditsSymbol').value = (credits.symbol ?? '$');
            const dailyAmountValue = parseInt(credits.daily_amount, 10);
            const dailyDelayValue = parseInt(credits.daily_login_delay_minutes, 10);
            const approvalBonusValue = parseInt(credits.approval_bonus, 10);
            const netmailCostValue = parseInt(credits.netmail_cost, 10);
            const echomailRewardValue = parseInt(credits.echomail_reward, 10);
            const crashmailCostValue = parseInt(credits.crashmail_cost, 10);
            const pollCreationCostValue = parseInt(credits.poll_creation_cost, 10);
            const new14DaysValue = parseInt(credits.return_14days, 10);
            const transferFeeValue = parseFloat(credits.transfer_fee_percent);
            document.getElementById('bbsCreditsDailyAmount').value = Number.isNaN(dailyAmountValue) ? 25 : dailyAmountValue;
            document.getElementById('bbsCreditsDailyDelay').value = Number.isNaN(dailyDelayValue) ? 5 : dailyDelayValue;
            document.getElementById('bbsCreditsApprovalBonus').value = Number.isNaN(approvalBonusValue) ? 100 : approvalBonusValue;
            document.getElementById('bbsCreditsNetmailCost').value = Number.isNaN(netmailCostValue) ? 1 : netmailCostValue;
            document.getElementById('bbsCreditsEchomailReward').value = Number.isNaN(echomailRewardValue) ? 3 : echomailRewardValue;
            document.getElementById('bbsCreditsCrashmailCost').value = Number.isNaN(crashmailCostValue) ? 10 : crashmailCostValue;
            document.getElementById('bbsCreditsPollCreationCost').value = Number.isNaN(pollCreationCostValue) ? 15 : pollCreationCostValue;
            document.getElementById('bbsCreditsNew14Days').value = Number.isNaN(new14DaysValue) ? 50 : new14DaysValue;
            document.getElementById('bbsCreditsTransferFee').value = Number.isNaN(transferFeeValue) ? 0.05 : transferFeeValue;

            const referralBonusValue = parseInt(credits.referral_bonus, 10);
            document.getElementById('bbsCreditsReferralEnabled').checked = !!credits.referral_enabled;
            document.getElementById('bbsCreditsReferralBonus').value = Number.isNaN(referralBonusValue) ? 25 : referralBonusValue;
        })
        .catch(error => {
            showBbsSettingsAlert(error.message || uiT('ui.admin.bbs_settings.load_failed', 'Failed to load settings'), 'danger');
        });
}

function saveBbsSettings() {
    const maxCrossPost = parseInt(document.getElementById('bbsMaxCrossPost').value, 10);
    if (Number.isNaN(maxCrossPost) || maxCrossPost < 2 || maxCrossPost > 20) {
        showBbsSettingsAlert(uiT('ui.admin.bbs_settings.validation.max_cross_post_areas_range', 'Max cross-post areas must be an integer between 2 and 20.'), 'danger');
        return;
    }

    // Get current credits settings (don't change them)
    fetch('/admin/api/bbs-settings')
        .then(response => response.json())
        .then(currentData => {
            const credits = currentData.config?.credits || {};

            const config = {
                features: {
                    webdoors: document.getElementById('bbsWebdoors').checked,
                    shoutbox: document.getElementById('bbsShoutbox').checked,
                    advertising: document.getElementById('bbsAdvertising').checked,
                    voting_booth: document.getElementById('bbsVoting').checked,
                    chat: document.getElementById('bbsChat').checked,
                    file_areas: document.getElementById('bbsFileAreas').checked
                },
                credits: credits,
                max_cross_post_areas: maxCrossPost,
                default_echo_interface: document.getElementById('bbsDefaultEchoInterface').value
            };

            return fetch('/admin/api/bbs-settings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ config })
            });
        })
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                throw new Error(apiError(data, uiT('ui.admin.bbs_settings.save_failed', 'Failed to save settings')));
            }
            const successMessage = window.getApiMessage
                ? window.getApiMessage(data, uiT('ui.admin.bbs_settings.saved_success', 'BBS features saved successfully.'))
                : uiT('ui.admin.bbs_settings.saved_success', 'BBS features saved successfully.');
            showBbsSettingsAlert(successMessage, 'success');
        })
        .catch(error => {
            showBbsSettingsAlert(error.message || uiT('ui.admin.bbs_settings.save_failed', 'Failed to save settings'), 'danger');
        });
}

function loadBbsSystem() {
    fetch('/admin/api/bbs-system')
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                throw new Error(apiError(data, uiT('ui.admin.bbs_settings.load_system_failed', 'Failed to load system settings')));
            }
            const config = data.config || {};
            document.getElementById('bbsSystemName').value = config.name || '';
            document.getElementById('bbsSystemSysop').dataset.currentValue = config.sysop || '';
            document.getElementById('bbsSystemLocation').value = config.location || '';
            document.getElementById('bbsSystemTimezone').value = config.timezone || 'UTC';
            document.getElementById('bbsSystemAddress').value = config.address || '';
            document.getElementById('bbsSystemOrigin').value = config.origin || '';
            syncSysopSelect('bbsSystemSysop');
        })
        .catch(error => {
            showBbsSystemAlert(error.message || uiT('ui.admin.bbs_settings.load_system_failed', 'Failed to load system settings'), 'danger');
        });
}

function saveBbsSystem() {
    const config = {
        name: document.getElementById('bbsSystemName').value.trim(),
        sysop: document.getElementById('bbsSystemSysop').value,
        location: document.getElementById('bbsSystemLocation').value.trim(),
        timezone: document.getElementById('bbsSystemTimezone').value,
        address: document.getElementById('bbsSystemAddress').value.trim(),
        origin: document.getElementById('bbsSystemOrigin').value.trim()
    };

    fetch('/admin/api/bbs-system', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ config })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            throw new Error(apiError(data, uiT('ui.admin.bbs_settings.save_system_failed', 'Failed to save system settings')));
        }
        const successMessage = window.getApiMessage
            ? window.getApiMessage(data, uiT('ui.admin.bbs_settings.system_saved_success', 'System settings saved successfully.'))
            : uiT('ui.admin.bbs_settings.system_saved_success', 'System settings saved successfully.');
        showBbsSystemAlert(successMessage, 'success');
    })
    .catch(error => {
        showBbsSystemAlert(error.message || uiT('ui.admin.bbs_settings.save_system_failed', 'Failed to save system settings'), 'danger');
    });
}

function saveBbsCredits() {
    const symbol = document.getElementById('bbsCreditsSymbol').value.trim();
    if (symbol.length > 5) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.currency_symbol_length', 'Currency symbol must be 0-5 characters.'), 'danger');
        return;
    }

    const dailyAmount = parseInt(document.getElementById('bbsCreditsDailyAmount').value, 10);
    if (Number.isNaN(dailyAmount) || dailyAmount < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.daily_login_amount_non_negative', 'Daily login amount must be a non-negative integer.'), 'danger');
        return;
    }

    const dailyDelay = parseInt(document.getElementById('bbsCreditsDailyDelay').value, 10);
    if (Number.isNaN(dailyDelay) || dailyDelay < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.daily_login_delay_non_negative', 'Daily login delay must be a non-negative integer.'), 'danger');
        return;
    }

    const approvalBonus = parseInt(document.getElementById('bbsCreditsApprovalBonus').value, 10);
    if (Number.isNaN(approvalBonus) || approvalBonus < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.approval_bonus_non_negative', 'Approval bonus must be a non-negative integer.'), 'danger');
        return;
    }

    const netmailCost = parseInt(document.getElementById('bbsCreditsNetmailCost').value, 10);
    if (Number.isNaN(netmailCost) || netmailCost < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.netmail_cost_non_negative', 'Netmail cost must be a non-negative integer.'), 'danger');
        return;
    }

    const echomailReward = parseInt(document.getElementById('bbsCreditsEchomailReward').value, 10);
    if (Number.isNaN(echomailReward) || echomailReward < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.echomail_reward_non_negative', 'Echomail reward must be a non-negative integer.'), 'danger');
        return;
    }

    const crashmailCost = parseInt(document.getElementById('bbsCreditsCrashmailCost').value, 10);
    if (Number.isNaN(crashmailCost) || crashmailCost < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.crashmail_cost_non_negative', 'Crashmail cost must be a non-negative integer.'), 'danger');
        return;
    }

    const pollCreationCost = parseInt(document.getElementById('bbsCreditsPollCreationCost').value, 10);
    if (Number.isNaN(pollCreationCost) || pollCreationCost < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.poll_creation_cost_non_negative', 'Poll creation cost must be a non-negative integer.'), 'danger');
        return;
    }

    const new14Days = parseInt(document.getElementById('bbsCreditsNew14Days').value, 10);
    if (Number.isNaN(new14Days) || new14Days < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.return_14_days_non_negative', '14-day return bonus must be a non-negative integer.'), 'danger');
        return;
    }

    const transferFee = parseFloat(document.getElementById('bbsCreditsTransferFee').value);
    if (Number.isNaN(transferFee) || transferFee < 0 || transferFee > 1) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.transfer_fee_range', 'Transfer fee must be between 0 and 1 (0% to 100%).'), 'danger');
        return;
    }

    const referralBonus = parseInt(document.getElementById('bbsCreditsReferralBonus').value, 10);
    if (Number.isNaN(referralBonus) || referralBonus < 0) {
        showBbsCreditsAlert(uiT('ui.admin.bbs_settings.validation.referral_bonus_non_negative', 'Referral bonus must be a non-negative integer.'), 'danger');
        return;
    }

    // Get current BBS features settings (don't change them)
    fetch('/admin/api/bbs-settings')
        .then(response => response.json())
        .then(currentData => {
            const features = currentData.config?.features || {};

            const config = {
                features: features,
                credits: {
                    enabled: document.getElementById('bbsCreditsEnabled').checked,
                    symbol: symbol,
                    daily_amount: dailyAmount,
                    daily_login_delay_minutes: dailyDelay,
                    approval_bonus: approvalBonus,
                    netmail_cost: netmailCost,
                    echomail_reward: echomailReward,
                    crashmail_cost: crashmailCost,
                    poll_creation_cost: pollCreationCost,
                    return_14days: new14Days,
                    transfer_fee_percent: transferFee,
                    referral_enabled: document.getElementById('bbsCreditsReferralEnabled').checked,
                    referral_bonus: referralBonus
                }
            };

            return fetch('/admin/api/bbs-settings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ config })
            });
        })
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                throw new Error(apiError(data, uiT('ui.admin.bbs_settings.save_credits_failed', 'Failed to save credits settings')));
            }
            const successMessage = window.getApiMessage
                ? window.getApiMessage(data, uiT('ui.admin.bbs_settings.credits_saved_success', 'Credits settings saved successfully.'))
                : uiT('ui.admin.bbs_settings.credits_saved_success', 'Credits settings saved successfully.');
            showBbsCreditsAlert(successMessage, 'success');
        })
        .catch(error => {
            showBbsCreditsAlert(error.message || uiT('ui.admin.bbs_settings.save_credits_failed', 'Failed to save credits settings'), 'danger');
        });
}

function loadBbsTaglines() {
    fetch('/admin/api/taglines')
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                throw new Error(apiError(data, uiT('ui.admin.bbs_settings.load_taglines_failed', 'Failed to load taglines')));
            }
            document.getElementById('bbsTaglinesText').value = data.taglines || '';
        })
        .catch(error => {
            showBbsTaglinesAlert(error.message || uiT('ui.admin.bbs_settings.load_taglines_failed', 'Failed to load taglines'), 'danger');
        });
}

function saveBbsTaglines() {
    const text = document.getElementById('bbsTaglinesText').value || '';
    fetch('/admin/api/taglines', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ taglines: text })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            throw new Error(apiError(data, uiT('ui.admin.bbs_settings.save_taglines_failed', 'Failed to save taglines')));
        }
        const successMessage = window.getApiMessage
            ? window.getApiMessage(data, uiT('ui.admin.bbs_settings.taglines_saved_success', 'Taglines saved successfully.'))
            : uiT('ui.admin.bbs_settings.taglines_saved_success', 'Taglines saved successfully.');
        showBbsTaglinesAlert(successMessage, 'success');
    })
    .catch(error => {
        showBbsTaglinesAlert(error.message || uiT('ui.admin.bbs_settings.save_taglines_failed', 'Failed to save taglines'), 'danger');
    });
}

