{% extends "base.twig" %}

{% block title %}{{ t('ui.admin.users.page_title', {}, locale, ['common']) }}{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">{{ t('ui.admin.users.heading', {}, locale, ['common']) }}</h1>
        <button type="button" class="btn btn-primary" onclick="showCreateUserModal()">
            <i class="fas fa-plus me-2"></i>{{ t('ui.admin.users.add_new_user', {}, locale, ['common']) }}
        </button>
    </div>

    <!-- Search and Filter -->
    <div class="row mb-3">
        <div class="col-md-6">
            <input type="text" class="form-control" id="searchInput" placeholder="{{ t('ui.admin.users.search_users_placeholder', {}, locale, ['common']) }}" onkeyup="searchUsers()">
        </div>
        <div class="col-md-6 text-end">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-secondary" onclick="filterUsers('all')">{{ t('ui.common.all', {}, locale, ['common']) }}</button>
                <button type="button" class="btn btn-outline-secondary" onclick="filterUsers('active')">{{ t('ui.admin.users.active', {}, locale, ['common']) }}</button>
                <button type="button" class="btn btn-outline-secondary" onclick="filterUsers('admin')">{{ t('ui.admin.users.admins', {}, locale, ['common']) }}</button>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="usersTable">
                    <thead class="table-dark">
                        <tr>
                            <th>{{ t('ui.common.id', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.username', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.real_name', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.fidonet_address', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.common.email', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.status', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.admin', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.created', {}, locale, ['common']) }}</th>
                            <th>{{ t('ui.admin.users.actions', {}, locale, ['common']) }}</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <nav aria-label="{{ t('ui.admin.users.pagination_aria', {}, locale, ['common']) }}">
                <ul class="pagination justify-content-center" id="usersPagination">
                    <!-- Populated by JavaScript -->
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Create/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userModalLabel">{{ t('ui.admin.users.add_new_user', {}, locale, ['common']) }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ t('ui.common.close', {}, locale, ['common']) }}"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId" name="userId">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="username" class="form-label">{{ t('ui.admin.users.username', {}, locale, ['common']) }} <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="username" name="username" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="realName" class="form-label">{{ t('ui.admin.users.real_name', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="realName" name="real_name">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label">{{ t('ui.common.email', {}, locale, ['common']) }}</label>
                            <input type="email" class="form-control" id="email" name="email">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="fidonetAddress" class="form-label">{{ t('ui.admin.users.fidonet_address', {}, locale, ['common']) }}</label>
                            <input type="text" class="form-control" id="fidonetAddress" name="fidonet_address" placeholder="{{ t('ui.admin.users.fidonet_address_placeholder', {}, locale, ['common']) }}">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="password" class="form-label">{{ t('ui.common.password', {}, locale, ['common']) }} <span id="passwordRequired" class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="password" name="password">
                            <small class="form-text text-muted" id="passwordHelp">{{ t('ui.admin.users.password_help', {}, locale, ['common']) }}</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="isActive" name="is_active" checked>
                                <label class="form-check-label" for="isActive">
                                    {{ t('ui.admin.users.active_user', {}, locale, ['common']) }}
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isAdmin" name="is_admin">
                                <label class="form-check-label" for="isAdmin">
                                    {{ t('ui.admin.users.administrator', {}, locale, ['common']) }}
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('ui.common.cancel', {}, locale, ['common']) }}</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">{{ t('ui.admin.users.save_user', {}, locale, ['common']) }}</button>
            </div>
        </div>
    </div>
</div>

<!-- User Details Modal -->
<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userDetailsModalLabel">{{ t('ui.admin.users.user_details', {}, locale, ['common']) }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ t('ui.common.close', {}, locale, ['common']) }}"></button>
            </div>
            <div class="modal-body" id="userDetailsBody">
                <!-- Populated by JavaScript -->
            </div>
        </div>
    </div>
</div>

<script>
let currentPage = 1;
let currentSearch = '';
let currentFilter = 'all';
function apiError(payload, fallback) {
    if (window.getApiErrorMessage) {
        return window.getApiErrorMessage(payload, fallback);
    }
    if (payload && payload.error) {
        return String(payload.error);
    }
    return fallback;
}

function uiT(key, fallback, params = {}) {
    if (window.t) {
        return window.t(key, params, fallback);
    }
    return fallback;
}

document.addEventListener('DOMContentLoaded', function() {
    loadUsers();
});

function loadUsers(page = 1) {
    currentPage = page;
    const searchParam = currentSearch ? `&search=${encodeURIComponent(currentSearch)}` : '';
    
    fetch(`/admin/api/users?page=${page}&limit=25${searchParam}`)
        .then(response => response.json())
        .then(data => {
            displayUsers(data.users);
            displayPagination(data.pagination);
        })
        .catch(error => {
            console.error(uiT('ui.admin.users.load_failed', 'Error loading users') + ':', error);
            showAlert(uiT('ui.admin.users.load_failed', 'Error loading users'), 'danger');
        });
}

function displayUsers(users) {
    const tbody = document.getElementById('usersTableBody');
    tbody.innerHTML = '';
    
    users.forEach(user => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${user.id}</td>
            <td>${user.username}</td>
            <td>${user.real_name || '-'}</td>
            <td>${user.fidonet_address || '-'}</td>
            <td>${user.email || '-'}</td>
            <td>
                <span class="badge bg-${user.is_active ? 'success' : 'danger'}">
                    ${user.is_active ? uiT('ui.admin.users.active', 'Active') : uiT('ui.admin.users.inactive', 'Inactive')}
                </span>
            </td>
            <td>
                ${user.is_admin ? '<span class="badge bg-warning">' + uiT('ui.admin.users.admin', 'Admin') + '</span>' : '-'}
            </td>
            <td>${new Date(user.created_at).toLocaleDateString()}</td>
            <td>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-info" onclick="viewUser(${user.id})" title="${uiT('ui.admin.users.view_details', 'View Details')}">
                        <i class="fas fa-eye"></i>
                    </button>
                    <a href="/profile/${encodeURIComponent(user.username)}" class="btn btn-outline-secondary btn-sm" title="${uiT('ui.admin.users.view_profile', 'View Profile')}" target="_blank">
                        <i class="fas fa-user"></i>
                    </a>
                    <button type="button" class="btn btn-outline-primary" onclick="editUser(${user.id})" title="${uiT('ui.common.edit', 'Edit')}">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="deleteUser(${user.id})" title="${uiT('ui.common.delete', 'Delete')}">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </td>
        `;
        tbody.appendChild(row);
    });
}

function displayPagination(pagination) {
    const nav = document.getElementById('usersPagination');
    nav.innerHTML = '';
    
    const totalPages = pagination.pages;
    const currentPage = pagination.page;
    
    // Previous button
    const prevItem = document.createElement('li');
    prevItem.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
    prevItem.innerHTML = `<a class="page-link" href="#" onclick="loadUsers(${currentPage - 1})">${uiT('ui.admin.users.previous', 'Previous')}</a>`;
    nav.appendChild(prevItem);
    
    // Page numbers
    for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) {
        const item = document.createElement('li');
        item.className = `page-item ${i === currentPage ? 'active' : ''}`;
        item.innerHTML = `<a class="page-link" href="#" onclick="loadUsers(${i})">${i}</a>`;
        nav.appendChild(item);
    }
    
    // Next button
    const nextItem = document.createElement('li');
    nextItem.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
    nextItem.innerHTML = `<a class="page-link" href="#" onclick="loadUsers(${currentPage + 1})">${uiT('ui.admin.users.next', 'Next')}</a>`;
    nav.appendChild(nextItem);
}

function searchUsers() {
    currentSearch = document.getElementById('searchInput').value;
    loadUsers(1);
}

function filterUsers(filter) {
    currentFilter = filter;
    // TODO: Implement filtering logic
    loadUsers(1);
}

function showCreateUserModal() {
    document.getElementById('userModalLabel').textContent = uiT('ui.admin.users.add_new_user', 'Add New User');
    document.getElementById('userForm').reset();
    document.getElementById('userId').value = '';
    document.getElementById('passwordRequired').style.display = 'inline';
    document.getElementById('passwordHelp').style.display = 'none';
    document.getElementById('password').required = true;
    new bootstrap.Modal(document.getElementById('userModal')).show();
}

function editUser(userId) {
    fetch(`/admin/api/users/${userId}`)
        .then(response => response.json())
        .then(data => {
            const user = data.user;
            document.getElementById('userModalLabel').textContent = uiT('ui.admin.users.edit_user', 'Edit User');
            document.getElementById('userId').value = user.id;
            document.getElementById('username').value = user.username;
            document.getElementById('realName').value = user.real_name || '';
            document.getElementById('email').value = user.email || '';
            document.getElementById('fidonetAddress').value = user.fidonet_address || '';
            document.getElementById('isActive').checked = user.is_active;
            document.getElementById('isAdmin').checked = user.is_admin;
            document.getElementById('password').value = '';
            document.getElementById('password').required = false;
            document.getElementById('passwordRequired').style.display = 'none';
            document.getElementById('passwordHelp').style.display = 'block';

            new bootstrap.Modal(document.getElementById('userModal')).show();
        })
        .catch(error => {
            console.error(uiT('ui.admin.users.load_details_failed', 'Error loading user details') + ':', error);
            showAlert(uiT('ui.admin.users.load_details_failed', 'Error loading user details'), 'danger');
        });
}

function viewUser(userId) {
    fetch(`/admin/api/users/${userId}`)
        .then(response => response.json())
        .then(data => {
            const user = data.user;
            const stats = user.stats;
            
            document.getElementById('userDetailsBody').innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <h6>${uiT('ui.admin.users.user_information', 'User Information')}</h6>
                        <p><strong>${uiT('ui.admin.users.username', 'Username')}:</strong> ${user.username}</p>
                        <p><strong>${uiT('ui.admin.users.real_name', 'Real Name')}:</strong> ${user.real_name || '-'}</p>
                        <p><strong>${uiT('ui.common.email', 'Email')}:</strong> ${user.email || '-'}</p>
                        <p><strong>${uiT('ui.admin.users.fidonet_address', 'Fidonet Address')}:</strong> ${user.fidonet_address || '-'}</p>
                        <p><strong>${uiT('ui.admin.users.status', 'Status')}:</strong> 
                            <span class="badge bg-${user.is_active ? 'success' : 'danger'}">
                                ${user.is_active ? uiT('ui.admin.users.active', 'Active') : uiT('ui.admin.users.inactive', 'Inactive')}
                            </span>
                            ${user.is_admin ? '<span class="badge bg-warning ms-1">' + uiT('ui.admin.users.admin', 'Admin') + '</span>' : ''}
                        </p>
                        <p><strong>${uiT('ui.admin.users.created', 'Created')}:</strong> ${new Date(user.created_at).toLocaleString()}</p>
                        <p><strong>${uiT('ui.admin.users.last_login', 'Last Login')}:</strong> ${user.last_login ? new Date(user.last_login).toLocaleString() : uiT('ui.common.never', 'Never')}</p>
                    </div>
                    <div class="col-md-6">
                        <h6>${uiT('ui.admin.users.statistics', 'Statistics')}</h6>
                        <p><strong>${uiT('ui.admin.users.netmail_received', 'Netmail Received')}:</strong> ${stats.netmail_received}</p>
                        <p><strong>${uiT('ui.admin.users.netmail_sent', 'Netmail Sent')}:</strong> ${stats.netmail_sent}</p>
                        <p><strong>${uiT('ui.admin.users.echomail_posted', 'Echomail Posted')}:</strong> ${stats.echomail_posted}</p>
                        <p><strong>${uiT('ui.admin.users.active_sessions', 'Active Sessions')}:</strong> ${stats.active_sessions}</p>
                    </div>
                </div>
            `;
            
            new bootstrap.Modal(document.getElementById('userDetailsModal')).show();
        })
        .catch(error => {
            console.error(uiT('ui.admin.users.load_details_failed', 'Error loading user details') + ':', error);
            showAlert(uiT('ui.admin.users.load_details_failed', 'Error loading user details'), 'danger');
        });
}

function saveUser() {
    const form = document.getElementById('userForm');
    const formData = new FormData(form);
    const userId = formData.get('userId');
    
    const userData = {
        username: formData.get('username'),
        real_name: formData.get('real_name'),
        email: formData.get('email'),
        fidonet_address: formData.get('fidonet_address'),
        is_active: formData.has('is_active'),
        is_admin: formData.has('is_admin')
    };
    
    if (formData.get('password')) {
        userData.password = formData.get('password');
    }
    
    const url = userId ? `/admin/api/users/${userId}` : '/admin/api/users';
    const method = userId ? 'PUT' : 'POST';
    
    fetch(url, {
        method: method,
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(userData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success || data.user_id) {
            const successMessage = window.getApiMessage
                ? window.getApiMessage(
                    data,
                    userId
                        ? uiT('ui.admin.users.updated_success', 'User updated successfully')
                        : uiT('ui.admin.users.created_success', 'User created successfully')
                )
                : (userId
                    ? uiT('ui.admin.users.updated_success', 'User updated successfully')
                    : uiT('ui.admin.users.created_success', 'User created successfully'));
            showAlert(successMessage, 'success');
            bootstrap.Modal.getInstance(document.getElementById('userModal')).hide();
            loadUsers(currentPage);
        } else {
            showAlert(apiError(data, uiT('ui.admin.users.save_failed', 'Error saving user')), 'danger');
        }
    })
    .catch(error => {
        console.error(uiT('ui.admin.users.save_failed', 'Error saving user') + ':', error);
        showAlert(uiT('ui.admin.users.save_failed', 'Error saving user'), 'danger');
    });
}

function deleteUser(userId) {
    if (confirm(uiT('ui.admin.users.delete_confirm', 'Are you sure you want to delete this user? This action cannot be undone.'))) {
        fetch(`/admin/api/users/${userId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const successMessage = window.getApiMessage
                    ? window.getApiMessage(data, uiT('ui.admin.users.deleted_success', 'User deleted successfully'))
                    : uiT('ui.admin.users.deleted_success', 'User deleted successfully');
                showAlert(successMessage, 'success');
                loadUsers(currentPage);
            } else {
                showAlert(apiError(data, uiT('ui.admin.users.delete_failed', 'Error deleting user')), 'danger');
            }
        })
        .catch(error => {
            console.error(uiT('ui.admin.users.delete_failed', 'Error deleting user') + ':', error);
            showAlert(uiT('ui.admin.users.delete_failed', 'Error deleting user'), 'danger');
        });
    }
}

function showAlert(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
    alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    const container = document.querySelector('.container-fluid');
    container.insertBefore(alertDiv, container.firstChild);
    
    setTimeout(() => {
        alertDiv.remove();
    }, 5000);
}
</script>
{% endblock %}
