{% extends "base.twig" %}

{% block title %}{{ t('ui.admin.dashboard.page_title', {}, 'Admin Dashboard') }}{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">{{ t('ui.admin.dashboard.heading', {}, 'Admin Dashboard') }}</h1>
    </div>

    <!-- System Statistics -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">{{ t('ui.admin.dashboard.total_users', {}, 'Total Users') }}</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.total_users }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">{{ t('ui.admin.dashboard.active_users', {}, 'Active Users') }}</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.active_users }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">{{ t('ui.admin.dashboard.total_netmail', {}, 'Total Netmail') }}</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.total_netmail }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-envelope fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">{{ t('ui.admin.dashboard.total_echomail', {}, 'Total Echomail') }}</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.total_echomail }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-comments fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">{{ t('ui.admin.dashboard.quick_actions', {}, 'Quick Actions') }}</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/admin/users" class="btn btn-primary">
                            <i class="fas fa-users me-2"></i>{{ t('ui.base.admin.manage_users', {}, 'Manage Users') }}
                        </a>
                        <a href="/binkp" class="btn btn-secondary">
                            <i class="fas fa-network-wired me-2"></i>{{ t('ui.base.admin.binkp_status', {}, 'Binkp Status') }}
                        </a>
                        <a href="/echoareas" class="btn btn-info">
                            <i class="fas fa-comments me-2"></i>{{ t('ui.base.admin.echo_areas', {}, 'Echo Areas') }}
                        </a>
                        <a href="/admin/crashmail" class="btn btn-warning">
                            <i class="fas fa-bolt me-2"></i>{{ t('ui.admin.crashmail_queue.heading', {}, 'Crashmail Queue') }}
                        </a>
                        <a href="/admin/insecure-nodes" class="btn btn-outline-secondary">
                            <i class="fas fa-shield-alt me-2"></i>{{ t('ui.admin.insecure_nodes.heading', {}, 'Insecure Node Allowlist') }}
                        </a>
                        <a href="/admin/binkp-sessions" class="btn btn-outline-info">
                            <i class="fas fa-history me-2"></i>{{ t('ui.admin.binkp_sessions.heading', {}, 'Binkp Session Log') }}
                        </a>
                        <a href="/admin/activity-stats" class="btn btn-outline-primary">
                            <i class="fas fa-chart-bar me-2"></i>{{ t('ui.base.admin.activity_stats', {}, 'Activity Statistics') }}
                        </a>
                        <a href="/admin/economy" class="btn btn-outline-success">
                            <i class="fas fa-coins me-2"></i>{{ t('ui.base.admin.economy_viewer', {}, 'Economy Viewer') }}
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">{{ t('ui.admin.dashboard.system_information', {}, 'System Information') }}</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.admin_users', {}, 'Admin Users:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {{ stats.admin_users }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.active_sessions', {}, 'Active Sessions:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {{ stats.active_sessions }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.system_address', {}, 'System Address:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {% if system_addresses is defined and system_addresses|length > 0 %}
                                {{ system_addresses|join(', ') }}
                            {% else %}
                                {{ fidonetOrigin }}
                            {% endif %}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.version', {}, 'Version:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {{ app_version }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.git_branch_commit', {}, 'Git Branch / Commit:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {% if git_branch %}
                                <span class="badge bg-info">{{ git_branch }}</span>
                            {% endif %}
                            {% if git_commit %}
                                <span class="text-muted">{{ git_commit|slice(0, 8) }}</span>
                            {% else %}
                                <span class="text-muted">{{ t('ui.common.not_applicable', {}, 'n/a') }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.database_version', {}, 'Database Version:') }}</strong>
                        </div>
                        <div class="col-sm-6">
                            {% if db_version %}
                                <span class="text-muted">{{ db_version }}</span>
                            {% else %}
                                <span class="text-muted">{{ t('ui.common.not_applicable', {}, 'n/a') }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">{{ t('ui.admin.dashboard.service_status', {}, 'Service Status') }}</h6>
                </div>
                <div class="card-body">
                    {% set services = {
                        'admin_daemon': t('ui.admin.dashboard.service.admin_daemon', {}, 'Admin Daemon'),
                        'binkp_scheduler': t('ui.admin.dashboard.service.binkp_scheduler', {}, 'Binkp Scheduler'),
                        'binkp_server': t('ui.admin.dashboard.service.binkp_server', {}, 'Binkp Server'),
                        'telnetd': t('ui.admin.dashboard.service.telnetd', {}, 'Telnet Server')
                    } %}
                    {% for key, label in services %}
                        {% set info = daemon_status[key] ?? null %}
                        <div class="row align-items-center">
                            <div class="col-sm-6">
                                <strong>{{ label }}:</strong>
                            </div>
                            <div class="col-sm-6">
                                {% if info and info.running %}
                                    <span class="badge bg-success">{{ t('ui.admin.dashboard.running', {}, 'Running') }}</span>
                                {% else %}
                                    <span class="badge bg-danger">{{ t('ui.admin.dashboard.stopped', {}, 'Stopped') }}</span>
                                {% endif %}
                                {% if info and info.pid %}
                                    <small class="text-muted ms-2">{{ t('ui.admin.dashboard.pid', {}, 'PID') }} {{ info.pid }}</small>
                                {% endif %}
                            </div>
                        </div>
                        {% if not loop.last %}
                            <hr>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

</div>

<style>
.border-left-primary {
    border-left: 0.25rem solid #4e73df !important;
}
.border-left-success {
    border-left: 0.25rem solid #1cc88a !important;
}
.border-left-info {
    border-left: 0.25rem solid #36b9cc !important;
}
.border-left-warning {
    border-left: 0.25rem solid #f6c23e !important;
}

/* Recent Updates Styling for Admin Dashboard */
/* Background colors are handled by theme stylesheets */
.update-item {
    border-left: 3px solid #4e73df;
    padding-left: 0.75rem;
    border-radius: 0.25rem;
    padding: 0.75rem;
    margin-bottom: 0.75rem !important;
}

.update-item:hover {
    transition: background-color 0.2s ease;
}

.update-item .badge {
    font-size: 0.7em;
}

.update-item h6 {
    line-height: 1.2;
}

.update-item p {
    font-size: 0.9em;
    line-height: 1.3;
}
</style>
{% endblock %}
