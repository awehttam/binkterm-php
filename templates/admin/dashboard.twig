                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.load_average', {}, locale, ['common']) }}</strong>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted">{{ stats.load_average ?? t('ui.admin.dashboard.metric_unavailable', {}, locale, ['common']) }}</span>
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
