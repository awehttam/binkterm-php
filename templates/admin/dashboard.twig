                                    {{ stats.ram_usage }}
                                </button>
                            {% else %}
                                <span class="text-muted">{{ t('ui.admin.dashboard.metric_unavailable', {}, locale, ['common']) }}</span>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}
                    <hr>
                    <div class="row">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.system_address', {}, locale, ['common']) }}</strong>
                        </div>
                        <div class="col-sm-6">
