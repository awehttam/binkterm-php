                    <hr>
                    <div class="row align-items-center">
                        <div class="col-sm-6">
                            <strong>{{ t('ui.admin.dashboard.db_size', {}, locale, ['common']) }}</strong>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted">{{ db_summary.db_size ?? 'N/A' }}</span>
